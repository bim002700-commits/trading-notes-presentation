{
  "Uuid": "5a896cfe-7a69-44c8-9a9c-bc1ee9c0ae12",
  "IsCustomNode": false,
  "Description": "🔄操作說明：開啟檔案/執行/自動匯出NWC。",
  "Name": "FT-匯出NWC",
  "ElementResolver": {
    "ResolutionMap": {}
  },
  "Inputs": [],
  "Outputs": [],
  "Nodes": [
    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "import clr\r\nimport os\r\n\r\n# 引用 Revit API\r\nclr.AddReference('RevitAPI')\r\nfrom Autodesk.Revit.DB import *\r\n\r\n# 引用 Revit 服務\r\nclr.AddReference('RevitServices')\r\nfrom RevitServices.Persistence import DocumentManager\r\n\r\n# 取得目前的 Revit 文件\r\ndoc = DocumentManager.Instance.CurrentDBDocument\r\n\r\ntry:\r\n    # 1. 處理檔案路徑與檔名\r\n    if doc.IsModelInCloud:\r\n        # 如果是 BIM 360/ACC 雲端模型，預設匯出到桌面\r\n        folder = os.path.join(os.environ['USERPROFILE'], 'Desktop')\r\n        nwc_name = doc.Title\r\n    else:\r\n        # 本地檔案則匯出至同資料夾\r\n        current_path = doc.PathName\r\n        folder = os.path.normpath(os.path.dirname(current_path))\r\n        filename = os.path.basename(current_path)\r\n        nwc_name = os.path.splitext(filename)[0]\r\n\r\n    # 2. 設定 NWC 匯出選項 (依據截圖設定)\r\n    nwc_opt = NavisworksExportOptions()\r\n    \r\n    # 匯出範圍：目前視圖\r\n    nwc_opt.ExportScope = NavisworksExportScope.View\r\n    nwc_opt.ViewId = doc.ActiveView.Id\r\n    \r\n    # --- 座標設定：專案內部 (Project Internal) ---\r\n    nwc_opt.Coordinates = NavisworksCoordinates.Internal\r\n    \r\n    # --- 關鍵參數設定 (對應圖片中的勾選項) ---\r\n    nwc_opt.ConvertElementProperties = True      # 元素的類型性質\r\n    nwc_opt.FacetingFactor = 1.0                 # 刻面係數\r\n    nwc_opt.ExportLinks = True                   # 包含連結檔\r\n    nwc_opt.DivideFileIntoLevels = True          # 將檔案分割為多個層級 (截圖中有勾選)\r\n    nwc_opt.ConvertRoomsToAttributes = True      # 將房間轉換為屬性\r\n    nwc_opt.ExportRoomGeometry = True            # 匯出房間幾何圖形\r\n    nwc_opt.ExportParts = True                   # 匯出零件\r\n    nwc_opt.FindMissingMaterials = False         # 嘗試尋找遺失材料 (截圖未勾選)\r\n\r\n    # 3. 執行匯出\r\n    # Revit Export 方法會自動處理副檔名，nwc_name 不需要加 \".nwc\"\r\n    doc.Export(folder, nwc_name, nwc_opt)\r\n\r\n    OUT = \"✅ NWC 匯出成功！\\n路徑：{}\\n檔名：{}.nwc\\n座標系統：專案內部\\n包含連結檔：是\".format(folder, nwc_name)\r\n\r\nexcept Exception as ex:\r\n    OUT = \"❌ 失敗：{}\\n類型：{}\".format(str(ex), type(ex).__name__)",
      "Engine": "CPython3",
      "EngineName": "CPython3",
      "VariableInputPorts": true,
      "Id": "e16747c99ef94da487f533bca3e27737",
