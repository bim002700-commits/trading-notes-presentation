{
  "Uuid": "c3cc3ed2-b682-4bca-bb4b-6e1638693ec0",
  "IsCustomNode": false,
  "Description": "✨操作說明：需輸入相關資訊",
  "Name": "FT-建立網格",
  "ElementResolver": {
    "ResolutionMap": {}
  },
  "Inputs": [
    {
      "Id": "63b7f472121c427194b408aa71a6d3e8",
      "Name": "網格CAD圖層",
