    },
    {
      "Id": "5d320e94b14c409c96d8b82e81898a52",
      "Name": "垂直起始名稱",
      "Type": "string",
      "Type2": "string",
      "Value": "f1",
      "Description": "建立一個字串。",
      "SelectedIndex": 0
    },
    {
      "Id": "4865145ffb004b2292339de0850caab2",
      "Name": "水平起始名稱",
      "Type": "string",
      "Type2": "string",
      "Value": "P6-A",
      "Description": "建立一個字串。",
      "SelectedIndex": 0
    }
  ],
  "Outputs": [],
  "Nodes": [
    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "# -*- coding: utf-8 -*-\r\nimport clr, math, re\r\n\r\nclr.AddReference(\"RevitAPI\")\r\nclr.AddReference(\"RevitServices\")\r\n\r\nfrom RevitServices.Persistence import DocumentManager\r\nfrom RevitServices.Transactions import TransactionManager\r\nfrom Autodesk.Revit.DB import (\r\n    FilteredElementCollector, ImportInstance, Grid,\r\n    Options, GeometryInstance, GraphicsStyle, Line, XYZ\r\n)\r\n\r\ndoc = DocumentManager.Instance.CurrentDBDocument\r\n\r\n# ── 1. 讀取輸入 (請確保節點有 4 個 IN 埠) ─────────────────────────\r\ndef get_input(index, default):\r\n    try: return str(IN[index]).strip() if IN[index] else default\r\n    except: return default\r\n\r\nv_layer_input = get_input(0, \"ccl\").lower()\r\nh_layer_input = get_input(1, \"ccl\").lower()\r\nv_start_name  = get_input(2, \"f1\")\r\nh_start_name  = get_input(3, \"P6-A\")\r\n\r\nlog = []\r\nlog.append(\"設定 - 垂直圖層:{} 起始:{}\".format(v_layer_input, v_start_name))\r\nlog.append(\"設定 - 水平圖層:{} 起始:{}\".format(h_layer_input, h_start_name))\r\n\r\n# ── 2. 命名產生器 (修正：確保 f1 優先被數字規則捕獲) ────────────────\r\ndef make_name_gen(start_name):\r\n    # 規則 A：數字結尾 (如 f1, 1, Grid1) -> 最優先\r\n    m_num = re.match(r'^(.*?)(\\d+)$', start_name)\r\n    if m_num:\r\n        prefix, num = m_num.group(1), int(m_num.group(2))\r\n        return lambda i: prefix + str(num + i)\r\n\r\n    # 規則 B：字母結尾 (如 P6-A, A)\r\n    m_alpha = re.match(r'^(.*?)([A-Za-z])$', start_name)\r\n    if m_alpha:\r\n        prefix, alpha = m_alpha.group(1), m_alpha.group(2).upper()\r\n        start_i = ord(alpha) - ord('A')\r\n        def gen_alpha(i):\r\n            idx = start_i + i\r\n            if idx <= 25: return prefix + chr(ord('A') + idx)\r\n            return prefix + chr(ord('A')+(idx//26)-1) + chr(ord('A')+(idx%26))\r\n        return gen_alpha\r\n\r\n    return lambda i: start_name + str(i+1)\r\n\r\nv_gen = make_name_gen(v_start_name)\r\nh_gen = make_name_gen(h_start_name)\r\n\r\n# ── 3. 幾何收集與遞迴遍歷 ─────────────────────────────\r\ndef get_all_lines(doc, target_layers):\r\n    opt = Options()\r\n    opt.IncludeNonVisibleObjects = True\r\n    results = []\r\n    \r\n    collector = FilteredElementCollector(doc).OfClass(ImportInstance).ToElements()\r\n    for cad in collector:\r\n        geo = cad.get_Geometry(opt)\r\n        if not geo: continue\r\n        \r\n        def process(geo_list):\r\n            inner_results = []\r\n            for o in geo_list:\r\n                if isinstance(o, GeometryInstance):\r\n                    inner_results.extend(process(o.GetInstanceGeometry()))\r\n                elif isinstance(o, Line):\r\n                    if not hasattr(o, \"GraphicsStyleId\"): continue\r\n                    style = doc.GetElement(o.GraphicsStyleId)\r\n                    if not style: continue\r\n                    \r\n                    full_name = style.GraphicsStyleCategory.Name.lower()\r\n                    # 圖層模糊匹配\r\n                    matched = next((l for l in target_layers if l in full_name), None)\r\n                    if matched:\r\n                        p0, p1 = o.GetEndPoint(0), o.GetEndPoint(1)\r\n                        # 只取水平面上的線 (Z值相近)\r\n                        if abs(p0.Z - p1.Z) < 0.1:\r\n                            inner_results.append((matched, p0, p1))\r\n            return inner_results\r\n        \r\n        results.extend(process(geo))\r\n    return results\r\n\r\nraw_data = get_all_lines(doc, {v_layer_input, h_layer_input})\r\n\r\n# ── 4. 去重與精確分類 ────────────────────────────────\r\ndef dedup_and_classify(data):\r\n    v_out, h_out = [], []\r\n    used_mids = []\r\n    \r\n    for layer, p0, p1 in data:\r\n        # 計算中點用於去重\r\n        mid = XYZ((p0.X+p1.X)/2, (p0.Y+p1.Y)/2, 0)\r\n        if any(mid.DistanceTo(prev) < 1.0 for prev in used_mids): continue\r\n        used_mids.append(mid)\r\n        \r\n        dx = abs(p1.X - p0.X)\r\n        dy = abs(p1.Y - p0.Y)\r\n        \r\n        # 核心判定：dy > dx 絕對是垂直線 (Vertical)\r\n        if dy > dx:\r\n            v_out.append((p0, p1))\r\n        else:\r\n            h_out.append((p0, p1))\r\n    return v_out, h_out\r\n\r\nv_lines, h_lines = dedup_and_classify(raw_data)\r\n\r\n# ── 5. 排序 (針對你的圖面習慣修正) ────────────────────────\r\n# 垂直軸網 (f1 系列)：由左至右排 (X 從小到大)\r\nfinal_v = sorted(v_lines, key=lambda pts: (pts[0].X + pts[1].X)/2)\r\n\r\n# 水平軸網 (P6-A 系列)：由上至下排 (Y 從大到小，解決 AD 在下面的問題)\r\nfinal_h = sorted(h_lines, key=lambda pts: (pts[0].Y + pts[1].Y)/2, reverse=True)\r\n\r\nlog.append(\"偵測結果 - 垂直:{} 條, 水平:{} 條\".format(len(final_v), len(final_h)))\r\n\r\n# ── 6. 建立 Revit 軸網 ─────────────────────────────\r\nexisting_names = set(g.Name for g in FilteredElementCollector(doc).OfClass(Grid))\r\n\r\nTransactionManager.Instance.EnsureInTransaction(doc)\r\n\r\n# 建立垂直軸網 (f1...)\r\nfor i, (p0, p1) in enumerate(final_v):\r\n    try:\r\n        g = Grid.Create(doc, Line.CreateBound(XYZ(p0.X, p0.Y, 0), XYZ(p1.X, p1.Y, 0)))\r\n        name = v_gen(i)\r\n        while name in existing_names: name += \"'\"\r\n        g.Name = name\r\n        existing_names.add(name)\r\n        log.append(\"✅ 垂直: {}\".format(name))\r\n    except Exception as ex: log.append(\"❌ 垂直失敗: {}\".format(ex))\r\n\r\n# 建立水平軸網 (P6-A...)\r\nfor i, (p0, p1) in enumerate(final_h):\r\n    try:\r\n        g = Grid.Create(doc, Line.CreateBound(XYZ(p0.X, p0.Y, 0), XYZ(p1.X, p1.Y, 0)))\r\n        name = h_gen(i)\r\n        while name in existing_names: name += \"'\"\r\n        g.Name = name\r\n        existing_names.add(name)\r\n        log.append(\"✅ 水平: {}\".format(name))\r\n    except Exception as ex: log.append(\"❌ 水平失敗: {}\".format(ex))\r\n\r\nTransactionManager.Instance.TransactionTaskDone()\r\n\r\nOUT = log",
      "Engine": "CPython3",
      "EngineName": "CPython3",
      "VariableInputPorts": true,
