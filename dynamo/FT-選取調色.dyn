  "Outputs": [],
  "Nodes": [
    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "import clr\r\nclr.AddReference('RevitAPI')\r\nclr.AddReference('RevitServices')\r\n\r\nfrom Autodesk.Revit.DB import *\r\nfrom RevitServices.Persistence import DocumentManager\r\nfrom RevitServices.Transactions import TransactionManager\r\n\r\ndoc = DocumentManager.Instance.CurrentDBDocument\r\nactive_view = doc.ActiveView\r\n\r\n# IN[0]：Select Model Elements\r\n# IN[1]：R (0~255)\r\n# IN[2]：G (0~255)\r\n# IN[3]：B (0~255)\r\n# IN[4]：Boolean Toggle — True=上色、False=還原原色\r\nelements = IN[0] if isinstance(IN[0], list) else [IN[0]]\r\nelements = [UnwrapElement(e) for e in elements]\r\n\r\napply_color = bool(IN[4])\r\n\r\nTransactionManager.Instance.EnsureInTransaction(doc)\r\n\r\ncount = 0\r\n\r\nif apply_color:\r\n    # --- 上色 ---\r\n    r, g, b = int(IN[1]), int(IN[2]), int(IN[3])\r\n    single_color = Color(r, g, b)\r\n\r\n    solid_fill_id = None\r\n    for fp in FilteredElementCollector(doc).OfClass(FillPatternElement).ToElements():\r\n        if fp.GetFillPattern().IsSolidFill:\r\n            solid_fill_id = fp.Id\r\n            break\r\n\r\n    for elem in elements:\r\n        try:\r\n            ogs = OverrideGraphicSettings()\r\n            ogs.SetProjectionLineColor(single_color)\r\n            ogs.SetSurfaceForegroundPatternColor(single_color)\r\n            ogs.SetSurfaceForegroundPatternVisible(True)\r\n            if solid_fill_id:\r\n                ogs.SetSurfaceForegroundPatternId(solid_fill_id)\r\n            active_view.SetElementOverrides(elem.Id, ogs)\r\n            count += 1\r\n        except:\r\n            pass\r\n    msg = f\"✅ 上色完成，{count} 個元素套用 RGB({r},{g},{b})\"\r\n\r\nelse:\r\n    # --- 還原（清除所有覆蓋）---\r\n    for elem in elements:\r\n        try:\r\n            active_view.SetElementOverrides(elem.Id, OverrideGraphicSettings())\r\n            count += 1\r\n        except:\r\n            pass\r\n    msg = f\"🔄 還原完成，{count} 個元素已清除覆蓋\"\r\n\r\nTransactionManager.Instance.TransactionTaskDone()\r\nOUT = [msg]",
      "Engine": "CPython3",
      "EngineName": "CPython3",
      "VariableInputPorts": true,
      "Id": "be700b8901a040f5b70ca0c09cd95380",
      "NodeType": "PythonScriptNode",
