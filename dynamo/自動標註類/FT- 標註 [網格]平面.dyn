  "Nodes": [
    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "import clr\r\nclr.AddReference('RevitAPI')\r\nfrom Autodesk.Revit.DB import *\r\nclr.AddReference('RevitServices')\r\nfrom RevitServices.Persistence import DocumentManager\r\nfrom RevitServices.Transactions import TransactionManager\r\n\r\nui_doc = DocumentManager.Instance.CurrentUIApplication.ActiveUIDocument\r\ndoc = ui_doc.Document\r\nactive_view = ui_doc.ActiveView\r\n\r\nrun           = IN[0]\r\ndim_type_name = IN[1] if IN[1] else \"FT-DIM(TXT_4mm)\"  # ← 新增：手動輸入標註類型名稱\r\noffset_cm     = float(IN[2]) if IN[2] is not None else 100.0\r\noffset_ft     = offset_cm / 30.48\r\nselected      = IN[3] if isinstance(IN[3], list) else [IN[3]]\r\nuse_selection = IN[4]\r\n\r\ndef get_dim_type_name(dt):\r\n    for bip in [BuiltInParameter.SYMBOL_NAME_PARAM, BuiltInParameter.ALL_MODEL_TYPE_NAME]:\r\n        try:\r\n            p = dt.get_Parameter(bip)\r\n            if p and p.AsString():\r\n                return p.AsString()\r\n        except:\r\n            continue\r\n    try:\r\n        return dt.Name\r\n    except:\r\n        return None\r\n\r\nif not run:\r\n    OUT = \"待機中\"\r\nelse:\r\n    view = active_view\r\n    if not isinstance(view, ViewPlan):\r\n        OUT = \"❌ 請切換至平面視圖再執行\"\r\n    else:\r\n        TransactionManager.Instance.EnsureInTransaction(doc)\r\n        try:\r\n            # Step 1：找標註類型\r\n            dim_type = None\r\n            for dt in FilteredElementCollector(doc).OfClass(DimensionType):\r\n                name = get_dim_type_name(dt)\r\n                if name and name == dim_type_name:\r\n                    dim_type = dt\r\n                    break\r\n            if dim_type is None:\r\n                raise Exception(\"Step1❌ 找不到標註類型「{}」\".format(dim_type_name))\r\n\r\n            # Step 2：取得軸線\r\n            if use_selection and selected and selected[0] is not None:\r\n                all_grids = [UnwrapElement(e) for e in selected if isinstance(UnwrapElement(e), Grid)]\r\n            else:\r\n                all_grids = list(FilteredElementCollector(doc, view.Id).OfClass(Grid).ToElements())\r\n\r\n            # Step 3：分類\r\n            v_grids, h_grids = [], []\r\n            for g in all_grids:\r\n                try:\r\n                    p0, p1 = g.Curve.GetEndPoint(0), g.Curve.GetEndPoint(1)\r\n                    if abs(p0.X - p1.X) < 0.1: v_grids.append(g)\r\n                    elif abs(p0.Y - p1.Y) < 0.1: h_grids.append(g)\r\n                except:\r\n                    continue\r\n\r\n            v_grids.sort(key=lambda g: g.Curve.Evaluate(0.5, True).X)\r\n            h_grids.sort(key=lambda g: g.Curve.Evaluate(0.5, True).Y)\r\n\r\n            results = [\"視圖：{} | 垂直：{} 水平：{}\".format(view.Name, len(v_grids), len(h_grids))]\r\n            target_z   = view.Origin.Z\r\n            right_dir  = view.RightDirection.Normalize()\r\n            up_dir     = view.UpDirection.Normalize()\r\n\r\n            if len(v_grids) >= 2:\r\n                ra = ReferenceArray()\r\n                for g in v_grids: ra.Append(Reference(g))\r\n                all_y    = [g.Curve.GetEndPoint(i).Y for g in v_grids for i in range(2)]\r\n                line_pt  = XYZ(v_grids[0].Curve.Evaluate(0.5, True).X, max(all_y) + offset_ft, target_z)\r\n                doc.Create.NewDimension(view, Line.CreateUnbound(line_pt, right_dir), ra, dim_type)\r\n                results.append(\"✅ 橫向：{} 條\".format(len(v_grids)))\r\n\r\n            if len(h_grids) >= 2:\r\n                ra = ReferenceArray()\r\n                for g in h_grids: ra.Append(Reference(g))\r\n                all_x    = [g.Curve.GetEndPoint(i).X for g in h_grids for i in range(2)]\r\n                line_pt  = XYZ(min(all_x) - offset_ft, h_grids[0].Curve.Evaluate(0.5, True).Y, target_z)\r\n                doc.Create.NewDimension(view, Line.CreateUnbound(line_pt, up_dir), ra, dim_type)\r\n                results.append(\"✅ 縱向：{} 條\".format(len(h_grids)))\r\n\r\n            TransactionManager.Instance.TransactionTaskDone()\r\n            OUT = \"\\n\".join(results)\r\n\r\n        except Exception as e:\r\n            TransactionManager.Instance.ForceCloseTransaction()\r\n            OUT = \"❌ 錯誤原因：\" + str(e)",
      "Engine": "CPython3",
      "EngineName": "CPython3",
      "VariableInputPorts": true,
