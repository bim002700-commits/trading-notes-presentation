      "Id": "25c491df72f244e29a3b3ed7d1b50a9e",
      "Inputs": [],
      "Outputs": [
        {
          "Id": "6ea8f10d561c4c16b3b052c02c7ee2d6",
          "Name": "Elements",
          "Description": "選取的元素。",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Replication": "Disabled",
      "Description": "從 Revit 文件中選取多個元素。"
    },
    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "import math\r\nfrom Autodesk.Revit.DB import FilteredElementCollector, DimensionType\r\nfrom Autodesk.Revit.DB import Options, ViewDetailLevel, GeometryInstance, Solid\r\nfrom Autodesk.Revit.DB import PlanarFace, Line, XYZ, ReferenceArray, Reference\r\nfrom Autodesk.Revit.DB import BuiltInCategory, BuiltInParameter\r\nfrom Autodesk.Revit.DB import UnitUtils, UnitTypeId\r\nfrom RevitServices.Persistence import DocumentManager\r\nfrom RevitServices.Transactions import TransactionManager\r\n\r\n\r\ndoc = DocumentManager.Instance.CurrentDBDocument\r\nview = doc.ActiveView\r\n\r\n# --- 1. 取得輸入參數 ---\r\nraw_elems = IN[0] if isinstance(IN[0], list) else [IN[0]]\r\ndim_type_name = IN[1]\r\ndist_far = float(IN[2]) if IN[2] is not None else 1000.0   # 外層 (70-305)\r\ndist_near = float(IN[3]) if IN[3] is not None else 600.0   # 內層 (35/35)\r\n\r\n# --- 2. 方向控制 (Boolean 切換) ---\r\n# True = 正向 (1), False = 負向 (-1)\r\nSIDE_X = 1 if IN[5] is True else -1\r\nSIDE_Y = 1 if IN[6] is True else -1\r\n\r\ndef ft(mm):\r\n    return UnitUtils.ConvertToInternalUnits(mm, UnitTypeId.Millimeters)\r\n\r\nD_NEAR = ft(dist_near) \r\nD_FAR = ft(dist_far)   \r\n\r\ndef unwrap(x):\r\n    return x.InternalElement if hasattr(x, 'InternalElement') else x\r\n\r\n# 獲取標註類型\r\nall_dt = list(FilteredElementCollector(doc).OfClass(DimensionType).ToElements())\r\ndim_type = next((dt for dt in all_dt if dt.get_Parameter(BuiltInParameter.ALL_MODEL_TYPE_NAME).AsString() == dim_type_name), None)\r\nif dim_type is None and all_dt: dim_type = all_dt[0]\r\n\r\n# 分類元件\r\ncols = []; grids_x = []; grids_y = []\r\nfor raw in raw_elems:\r\n    elem = unwrap(raw)\r\n    if elem is None: continue\r\n    cat_id = elem.Category.Id.IntegerValue\r\n    if cat_id in [int(BuiltInCategory.OST_StructuralColumns), int(BuiltInCategory.OST_Columns)]:\r\n        cols.append(elem)\r\n    elif cat_id == int(BuiltInCategory.OST_Grids):\r\n        c = elem.Curve\r\n        if isinstance(c, Line):\r\n            gd = c.Direction.Normalize()\r\n            if abs(gd.Y) > 0.7: grids_x.append(elem) # 垂直網格\r\n            elif abs(gd.X) > 0.7: grids_y.append(elem) # 水平網格\r\n\r\n# --- 強化搜尋函數：找尋最近的網格 ---\r\ndef get_nearest_grid_ref(target_pos, grids, axis):\r\n    nearest_ref = None\r\n    min_dist = ft(300) # 30cm 搜尋半徑\r\n    for g in grids:\r\n        g_pos = g.Curve.GetEndPoint(0).X if axis == 'X' else g.Curve.GetEndPoint(0).Y\r\n        dist = abs(g_pos - target_pos)\r\n        if dist < min_dist:\r\n            min_dist = dist\r\n            nearest_ref = Reference(g)\r\n    return nearest_ref\r\n\r\ndef get_face_refs(col_elem, normal_dir):\r\n    opts = Options(); opts.ComputeReferences = True; opts.DetailLevel = ViewDetailLevel.Fine\r\n    faces = []\r\n    try:\r\n        geo = col_elem.get_Geometry(opts)\r\n        for g_obj in geo:\r\n            parts = list(g_obj.GetInstanceGeometry()) if isinstance(g_obj, GeometryInstance) else [g_obj]\r\n            for part in parts:\r\n                if isinstance(part, Solid) and part.Volume > 0:\r\n                    for face in part.Faces:\r\n                        if isinstance(face, PlanarFace):\r\n                            dot = face.FaceNormal.Normalize().DotProduct(normal_dir)\r\n                            if abs(dot) > 0.99: faces.append((face.Reference, face.Origin.DotProduct(normal_dir)))\r\n    except: pass\r\n    faces.sort(key=lambda x: x[1])\r\n    return faces \r\n\r\ndef group_elements(elements, axis, tol=ft(200)):\r\n    groups = []\r\n    for e in elements:\r\n        bbox = e.get_BoundingBox(view)\r\n        pos = (bbox.Min.Y + bbox.Max.Y)/2 if axis == 'X' else (bbox.Min.X + bbox.Max.X)/2\r\n        found = False\r\n        for g in groups:\r\n            if abs(g['pos'] - pos) < tol:\r\n                g['items'].append(e); found = True; break\r\n        if not found: groups.append({'pos': pos, 'items': [e]})\r\n    return groups\r\n\r\nTransactionManager.Instance.EnsureInTransaction(doc)\r\n\r\n# --- X 方向邏輯 ---\r\nfor group in group_elements(cols, 'X'):\r\n    items = group['items']\r\n    ref_layer_far = [] \r\n    base_y = max(i.get_BoundingBox(view).Max.Y for i in items) if SIDE_X == 1 else min(i.get_BoundingBox(view).Min.Y for i in items)\r\n\r\n    for col in items:\r\n        bbox = col.get_BoundingBox(view); f_refs = get_face_refs(col, XYZ.BasisX)\r\n        if len(f_refs) < 2: continue\r\n        \r\n        mid_x = (bbox.Min.X + bbox.Max.X) / 2\r\n        col_grid_ref = get_nearest_grid_ref(mid_x, grids_x, 'X')\r\n\r\n        final_ref_near = ReferenceArray()\r\n        final_ref_near.Append(f_refs[0][0])\r\n        if col_grid_ref: final_ref_near.Append(col_grid_ref)\r\n        final_ref_near.Append(f_refs[-1][0])\r\n        \r\n        y_loc_near = base_y + (SIDE_X * D_NEAR)\r\n        ln_near = Line.CreateBound(XYZ(bbox.Min.X, y_loc_near, 0), XYZ(bbox.Max.X, y_loc_near, 0))\r\n        try:\r\n            dn = doc.Create.NewDimension(view, ln_near, final_ref_near)\r\n            if dim_type: dn.DimensionType = dim_type\r\n        except: pass\r\n            \r\n        ref_layer_far.append((f_refs[0][0], f_refs[0][1]))\r\n        ref_layer_far.append((f_refs[-1][0], f_refs[-1][1]))\r\n    \r\n    ref_layer_far.sort(key=lambda x: x[1])\r\n    final_ref_far = ReferenceArray(); lp = None\r\n    for r, p in ref_layer_far:\r\n        if lp is None or abs(p - lp) > ft(5): final_ref_far.Append(r); lp = p\r\n    \r\n    y_loc_far = base_y + (SIDE_X * D_FAR)\r\n    ln_far = Line.CreateBound(XYZ(min(i.get_BoundingBox(view).Min.X for i in items), y_loc_far, 0), \r\n                               XYZ(max(i.get_BoundingBox(view).Max.X for i in items), y_loc_far, 0))\r\n    try:\r\n        df = doc.Create.NewDimension(view, ln_far, final_ref_far)\r\n        if dim_type: df.DimensionType = dim_type\r\n    except: pass\r\n\r\n# --- Y 方向邏輯 (垂直) ---\r\nfor group in group_elements(cols, 'Y'):\r\n    items = group['items']\r\n    ref_layer_far_y = []\r\n    base_x = max(i.get_BoundingBox(view).Max.X for i in items) if SIDE_Y == 1 else min(i.get_BoundingBox(view).Min.X for i in items)\r\n\r\n    for col in items:\r\n        bbox = col.get_BoundingBox(view); f_refs = get_face_refs(col, XYZ.BasisY)\r\n        if len(f_refs) < 2: continue\r\n\r\n        mid_y = (bbox.Min.Y + bbox.Max.Y) / 2\r\n        col_grid_ref_y = get_nearest_grid_ref(mid_y, grids_y, 'Y')\r\n\r\n        final_ref_near_y = ReferenceArray()\r\n        final_ref_near_y.Append(f_refs[0][0])\r\n        if col_grid_ref_y: final_ref_near_y.Append(col_grid_ref_y)\r\n        final_ref_near_y.Append(f_refs[-1][0])\r\n        \r\n        x_loc_near = base_x + (SIDE_Y * D_NEAR)\r\n        ln_near_y = Line.CreateBound(XYZ(x_loc_near, bbox.Min.Y, 0), XYZ(x_loc_near, bbox.Max.Y, 0))\r\n        try:\r\n            dn_y = doc.Create.NewDimension(view, ln_near_y, final_ref_near_y)\r\n            if dim_type: dn_y.DimensionType = dim_type\r\n        except: pass\r\n\r\n        ref_layer_far_y.append((f_refs[0][0], f_refs[0][1]))\r\n        ref_layer_far_y.append((f_refs[-1][0], f_refs[-1][1]))\r\n    \r\n    ref_layer_far_y.sort(key=lambda x: x[1])\r\n    final_ref_far_y = ReferenceArray(); lp = None\r\n    for r, p in ref_layer_far_y:\r\n        if lp is None or abs(p - lp) > ft(5): final_ref_far_y.Append(r); lp = p\r\n            \r\n    x_loc_far = base_x + (SIDE_Y * D_FAR)\r\n    ln_far_y = Line.CreateBound(XYZ(x_loc_far, min(i.get_BoundingBox(view).Min.Y for i in items), 0), \r\n                                 XYZ(x_loc_far, max(i.get_BoundingBox(view).Max.Y for i in items), 0))\r\n    try:\r\n        df_y = doc.Create.NewDimension(view, ln_far_y, final_ref_far_y)\r\n        if dim_type: df_y.DimensionType = dim_type\r\n    except: pass\r\n\r\nTransactionManager.Instance.TransactionTaskDone()\r\n\r\nOUT = \"成功：已更新為 Boolean 方向控制\"",
      "Engine": "CPython3",
      "EngineName": "CPython3",
      "VariableInputPorts": true,
