    {
      "ConcreteType": "Dynamo.Nodes.DSModelElementsSelection, DSRevitNodesUI",
      "NodeType": "ExtensionNode",
      "InstanceId": [
        "15e4b5d2-7816-4822-9a6f-582621dd7f1f-000edd54",
        "15e4b5d2-7816-4822-9a6f-582621dd7f1f-000eddc5",
        "0b674385-02ea-47c1-b47a-9161015b8a2c-0010fb49",
        "0b674385-02ea-47c1-b47a-9161015b8a2c-0010fb4c",
        "0b674385-02ea-47c1-b47a-9161015b8a2c-0010fb4d",
        "0b674385-02ea-47c1-b47a-9161015b8a2c-0010fb4e",
        "0b674385-02ea-47c1-b47a-9161015b8a2c-0010fb53",
        "60dbfa67-06a0-4a09-aaef-13ba7a5a1d64-00111714",
        "60dbfa67-06a0-4a09-aaef-13ba7a5a1d64-00111b27",
        "60dbfa67-06a0-4a09-aaef-13ba7a5a1d64-00111f5a",
        "60dbfa67-06a0-4a09-aaef-13ba7a5a1d64-00111faa",
        "8440d9f5-2fea-4729-8d6e-5b3dd6aca467-0015b423",
        "36cfe4e1-c4f6-4d27-b1b4-279ba311d9c4-00166e8e",
        "302d37e5-0712-4144-9144-6bb8ea052c5d-001e1b1e",
        "e4b3f972-04f3-44b4-a701-6d57cef0a7b6-0021a363",
        "69c9732e-b82f-4a54-ab89-d39e8f07549d-0026045e",
        "69c9732e-b82f-4a54-ab89-d39e8f07549d-00260462",
        "69c9732e-b82f-4a54-ab89-d39e8f07549d-0026046a"
      ],
      "Id": "25934da146c44243a30cbcb79ae58214",
      "Inputs": [],
      "Outputs": [
        {
          "Id": "f4c20b3c43024210af0defaaaddff3c0",
          "Name": "Elements",
          "Description": "選取的元素。",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Replication": "Disabled",
      "Description": "從 Revit 文件中選取多個元素。"
    },
    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "import math\r\nfrom Autodesk.Revit.DB import FilteredElementCollector, DimensionType, Dimension\r\nfrom Autodesk.Revit.DB import Options, ViewDetailLevel, GeometryInstance, Solid\r\nfrom Autodesk.Revit.DB import PlanarFace, Line, XYZ, ReferenceArray, Reference\r\nfrom Autodesk.Revit.DB import BuiltInCategory, BuiltInParameter, LocationCurve\r\nfrom Autodesk.Revit.DB import UnitUtils, UnitTypeId\r\nfrom RevitServices.Persistence import DocumentManager\r\nfrom RevitServices.Transactions import TransactionManager\r\n\r\ndoc = DocumentManager.Instance.CurrentDBDocument\r\nview = doc.ActiveView\r\n\r\n# --- 1. 參數 ---\r\nraw_elems     = IN[0] if isinstance(IN[0], list) else [IN[0]]\r\nwall_dim_name = \"FT-DIM-WALL(TXT_4.0mm)\"\r\nvoid_dim_name = \"FT-DIM-VOID(TXT_4.0mm)\"\r\ndist_near     = float(IN[3]) if IN[3] is not None else 600.0\r\nSIDE_X        = 1 if IN[5] is True else -1\r\nSIDE_Y        = 1 if IN[6] is True else -1\r\n\r\ndef ft(mm):\r\n    return UnitUtils.ConvertToInternalUnits(mm, UnitTypeId.Millimeters)\r\n\r\nD_NEAR        = ft(dist_near)\r\nMIN_SPAN      = ft(50)\r\nCORNER_TOL    = ft(100)\r\nDOOR_WIN_CATS = {int(BuiltInCategory.OST_Doors), int(BuiltInCategory.OST_Windows)}\r\n\r\ndef unwrap(x):\r\n    return x.InternalElement if hasattr(x, 'InternalElement') else x\r\n\r\ndef safe_type_name(elem):\r\n    try:\r\n        t = doc.GetElement(elem.GetTypeId())\r\n        if t and t.Name: return t.Name\r\n    except: pass\r\n    try:\r\n        n = elem.Name\r\n        if n: return n\r\n    except: pass\r\n    return \"\"\r\n\r\n# --- 2. 標註型式 ---\r\nall_dt = list(FilteredElementCollector(doc).OfClass(DimensionType).ToElements())\r\ndef find_dt(name):\r\n    dt = next((d for d in all_dt\r\n               if d.get_Parameter(BuiltInParameter.ALL_MODEL_TYPE_NAME).AsString() == name), None)\r\n    return dt or (all_dt[0] if all_dt else None)\r\ndt_wall = find_dt(wall_dim_name)\r\ndt_void = find_dt(void_dim_name)\r\n\r\n# --- 3. 分類 ---\r\nh_walls = []; v_walls = []\r\nfor raw in raw_elems:\r\n    elem = unwrap(raw)\r\n    if elem is None: continue\r\n    try: cat_id = elem.Category.Id.IntegerValue\r\n    except: continue\r\n    if cat_id != int(BuiltInCategory.OST_Walls): continue\r\n    if \"RC\" not in safe_type_name(elem): continue\r\n    try:\r\n        lc = elem.Location\r\n        if isinstance(lc, LocationCurve):\r\n            p1 = lc.Curve.GetEndPoint(1); p0 = lc.Curve.GetEndPoint(0)\r\n            if abs(p1.X - p0.X) >= abs(p1.Y - p0.Y): h_walls.append(elem)\r\n            else: v_walls.append(elem)\r\n        else: h_walls.append(elem)\r\n    except: h_walls.append(elem)\r\n\r\n# --- 4. 輔助函式 ---\r\ndef collect_solid_faces(geo_iter, normal_dir, out, dot_tol=0.99):\r\n    for g_obj in geo_iter:\r\n        parts = [g_obj]\r\n        if isinstance(g_obj, GeometryInstance):\r\n            try: parts = list(g_obj.GetInstanceGeometry())\r\n            except: continue\r\n        for part in parts:\r\n            if isinstance(part, Solid) and part.Volume > 0:\r\n                for face in part.Faces:\r\n                    if isinstance(face, PlanarFace):\r\n                        dot = face.FaceNormal.Normalize().DotProduct(normal_dir)\r\n                        if abs(dot) > dot_tol:\r\n                            out.append((face.Reference, face.Origin.DotProduct(normal_dir)))\r\n\r\ndef get_all_faces_sorted(elem, normal_dir, tol_mm=10, dot_tol=0.99):\r\n    opts = Options(); opts.ComputeReferences = True; opts.DetailLevel = ViewDetailLevel.Fine\r\n    faces = []\r\n    try:\r\n        geo = elem.get_Geometry(opts)\r\n        if geo: collect_solid_faces(geo, normal_dir, faces, dot_tol)\r\n    except: pass\r\n    faces.sort(key=lambda x: x[1])\r\n    tol = ft(tol_mm); deduped = []\r\n    for f in faces:\r\n        if not deduped or abs(f[1] - deduped[-1][1]) > tol: deduped.append(f)\r\n    return deduped\r\n\r\ndef get_outer_two(faces):\r\n    return [faces[0], faces[-1]] if len(faces) >= 2 else faces\r\n\r\ndef find_face_near(faces, target, tol_mm=60):\r\n    tol = ft(tol_mm); best = None; best_d = tol\r\n    for ref, pos in faces:\r\n        d = abs(pos - target)\r\n        if d < best_d: best_d = d; best = ref\r\n    return best\r\n\r\ndef group_elements(elements, axis, tol=ft(500)):\r\n    groups = []\r\n    for e in elements:\r\n        try: bbox = e.get_BoundingBox(view)\r\n        except: continue\r\n        if not bbox: continue\r\n        pos = (bbox.Min.Y + bbox.Max.Y)/2 if axis=='X' else (bbox.Min.X + bbox.Max.X)/2\r\n        found = False\r\n        for g in groups:\r\n            if abs(g['pos'] - pos) < tol: g['items'].append(e); found = True; break\r\n        if not found: groups.append({'pos': pos, 'items': [e]})\r\n    return groups\r\n\r\ndef try_dim(p0, p1, ra, dt):\r\n    if ra.Size < 2: return False\r\n    if p0.DistanceTo(p1) < ft(1): return False\r\n    try:\r\n        d = doc.Create.NewDimension(view, Line.CreateBound(p0, p1), ra)\r\n        if d and dt: d.DimensionType = dt\r\n        return True\r\n    except: return False\r\n\r\ndef get_wall_actual_perp(wall, is_x):\r\n    \"\"\"取得牆的實際垂直方向（處理略微旋轉的牆）\"\"\"\r\n    try:\r\n        lc = wall.Location\r\n        if isinstance(lc, LocationCurve):\r\n            p0 = lc.Curve.GetEndPoint(0); p1 = lc.Curve.GetEndPoint(1)\r\n            dx = p1.X - p0.X; dy = p1.Y - p0.Y\r\n            ln = math.sqrt(dx*dx + dy*dy)\r\n            if ln > 1e-6:\r\n                return XYZ(-dy/ln, dx/ln, 0)\r\n    except: pass\r\n    return XYZ.BasisY if is_x else XYZ.BasisX\r\n\r\n# --- 5. 執行 ---\r\nTransactionManager.Instance.EnsureInTransaction(doc)\r\n\r\n# 清除舊標註\r\nclear_ids = set()\r\nif dt_wall: clear_ids.add(dt_wall.Id.IntegerValue)\r\nif dt_void: clear_ids.add(dt_void.Id.IntegerValue)\r\nfor d in list(FilteredElementCollector(doc, view.Id).OfClass(Dimension).ToElements()):\r\n    try:\r\n        if d.DimensionType.Id.IntegerValue in clear_ids: doc.Delete(d.Id)\r\n    except: pass\r\n\r\ndef wall_span(wall, normal_dir, dot_tol=0.99):\r\n    faces = get_all_faces_sorted(wall, normal_dir, dot_tol=dot_tol)\r\n    outer = get_outer_two(faces)\r\n    if len(outer) < 2: return None\r\n    lo, hi = outer[0][1], outer[-1][1]\r\n    if (hi - lo) < MIN_SPAN: return None\r\n    return lo, hi, outer[0][0], outer[-1][0]\r\n\r\nh_spans = {}; v_spans = {}\r\nfor w in h_walls:\r\n    s = wall_span(w, XYZ.BasisX)\r\n    if s: h_spans[w] = s\r\nfor w in v_walls:\r\n    s = wall_span(w, XYZ.BasisY)\r\n    if s: v_spans[w] = s\r\n\r\ndef run_group(walls_list, normal_dir, is_x):\r\n    side       = SIDE_X if is_x else SIDE_Y\r\n    group_axis = 'X' if is_x else 'Y'\r\n    perp_dir   = XYZ.BasisY if is_x else XYZ.BasisX\r\n    spans_dict = h_spans if is_x else v_spans\r\n    adj_walls  = v_walls if is_x else h_walls\r\n    adj_dir    = XYZ.BasisY if is_x else XYZ.BasisX\r\n\r\n    for group in group_elements(walls_list, group_axis):\r\n        items  = group['items']\r\n        bboxes = [i.get_BoundingBox(view) for i in items]\r\n        bboxes = [b for b in bboxes if b]\r\n        if not bboxes: continue\r\n\r\n        base = (max(b.Max.Y for b in bboxes) if (is_x and side==1) else\r\n                min(b.Min.Y for b in bboxes) if is_x else\r\n                max(b.Max.X for b in bboxes) if side==1 else\r\n                min(b.Min.X for b in bboxes))\r\n        near_coord = base + side * D_NEAR\r\n\r\n        for item in items:\r\n            sp = spans_dict.get(item)\r\n            if not sp: continue\r\n            lo, hi, lo_r, hi_r = sp\r\n\r\n            # ── A. 牆長+開口連續標（直接用牆幾何所有法向面，含開口夾面）──\r\n            # 修正1：用 all_dir_faces 取代手動拼接 bbox，避免 \"0\" 及遺漏小段\r\n            all_dir_faces = get_all_faces_sorted(item, normal_dir)\r\n\r\n            # 只保留牆跨度範圍內的面（lo±5mm ~ hi±5mm）\r\n            span_faces = [(ref, pos) for ref, pos in all_dir_faces\r\n                          if lo - ft(5) <= pos <= hi + ft(5)]\r\n\r\n            # 確保兩端面存在\r\n            if not span_faces:\r\n                span_faces = [(lo_r, lo), (hi_r, hi)]\r\n            else:\r\n                if abs(span_faces[0][1] - lo) > ft(5):\r\n                    span_faces.insert(0, (lo_r, lo))\r\n                if abs(span_faces[-1][1] - hi) > ft(5):\r\n                    span_faces.append((hi_r, hi))\r\n\r\n            # 去重：確保相鄰位置差 > ft(5)，消除潛在 \"0\" 段\r\n            deduped = [span_faces[0]]\r\n            for ref, pos in span_faces[1:]:\r\n                if abs(pos - deduped[-1][1]) > ft(5):\r\n                    deduped.append((ref, pos))\r\n\r\n            if len(deduped) >= 2:\r\n                ra = ReferenceArray()\r\n                for ref, _ in deduped: ra.Append(ref)\r\n                p0 = XYZ(deduped[0][1],  near_coord, 0) if is_x else XYZ(near_coord, deduped[0][1],  0)\r\n                p1 = XYZ(deduped[-1][1], near_coord, 0) if is_x else XYZ(near_coord, deduped[-1][1], 0)\r\n                try_dim(p0, p1, ra, dt_wall)\r\n\r\n            # ── B. 開口 VOID 標 ──\r\n            try:\r\n                for ins_id in item.FindInserts(False, False, False, False):\r\n                    ins = doc.GetElement(ins_id)\r\n                    if ins is None: continue\r\n                    try: ins_cat = ins.Category.Id.IntegerValue\r\n                    except: continue\r\n                    if ins_cat not in DOOR_WIN_CATS: continue\r\n                    try:\r\n                        ins_bbox = ins.get_BoundingBox(view) or ins.get_BoundingBox(None)\r\n                        if not ins_bbox: continue\r\n                        i_lo = ins_bbox.Min.X if is_x else ins_bbox.Min.Y\r\n                        i_hi = ins_bbox.Max.X if is_x else ins_bbox.Max.Y\r\n                        if (i_hi - i_lo) < MIN_SPAN: continue\r\n                        r_lo = find_face_near(all_dir_faces, i_lo)\r\n                        r_hi = find_face_near(all_dir_faces, i_hi)\r\n                        if not r_lo or not r_hi: continue\r\n                        ra_v = ReferenceArray(); ra_v.Append(r_lo); ra_v.Append(r_hi)\r\n                        vp0 = XYZ(i_lo, near_coord, 0) if is_x else XYZ(near_coord, i_lo, 0)\r\n                        vp1 = XYZ(i_hi, near_coord, 0) if is_x else XYZ(near_coord, i_hi, 0)\r\n                        try_dim(vp0, vp1, ra_v, dt_void)\r\n                    except: continue\r\n            except: pass\r\n\r\n            # ── C. 牆厚（修正2：用實際法向 + dot_tol=0.95，處理 145 牆遺漏）──\r\n            actual_perp = get_wall_actual_perp(item, is_x)\r\n            th_faces_all = get_all_faces_sorted(item, actual_perp, tol_mm=5, dot_tol=0.95)\r\n            th_faces = get_outer_two(th_faces_all)\r\n            if len(th_faces) < 2: continue\r\n            t0, t1 = th_faces[0][1], th_faces[-1][1]\r\n            if (t1 - t0) < ft(1): continue\r\n\r\n            # ── D. 牆厚 + 鄰接垂直牆長連續（角落拼接）──\r\n            for end_pos in [lo, hi]:\r\n                for adj in adj_walls:\r\n                    adj_bbox = adj.get_BoundingBox(view)\r\n                    if not adj_bbox: continue\r\n                    if is_x:\r\n                        adj_range = (adj_bbox.Min.X, adj_bbox.Max.X)\r\n                        my_perp_range = (t0, t1)\r\n                    else:\r\n                        adj_range = (adj_bbox.Min.Y, adj_bbox.Max.Y)\r\n                        my_perp_range = (t0, t1)\r\n                    if adj_range[1] < my_perp_range[0] - CORNER_TOL: continue\r\n                    if adj_range[0] > my_perp_range[1] + CORNER_TOL: continue\r\n\r\n                    adj_sp = wall_span(adj, adj_dir)\r\n                    if not adj_sp: continue\r\n                    a_lo, a_hi, a_lo_r, a_hi_r = adj_sp\r\n\r\n                    matched = None\r\n                    if abs(a_lo - end_pos) < CORNER_TOL: matched = (a_lo_r, a_hi_r, a_lo, a_hi)\r\n                    elif abs(a_hi - end_pos) < CORNER_TOL: matched = (a_hi_r, a_lo_r, a_hi, a_lo)\r\n                    if not matched: continue\r\n\r\n                    near_t = t0 if abs(t0 - end_pos) < abs(t1 - end_pos) else t1\r\n                    far_t  = t1 if near_t == t0 else t0\r\n                    near_t_ref = th_faces[0][0] if th_faces[0][1] == near_t else th_faces[-1][0]\r\n                    far_t_ref  = th_faces[-1][0] if near_t_ref == th_faces[0][0] else th_faces[0][0]\r\n\r\n                    adj_start_r, adj_end_r, adj_start_p, adj_end_p = matched\r\n\r\n                    ra_c = ReferenceArray()\r\n                    ra_c.Append(far_t_ref)\r\n                    ra_c.Append(near_t_ref)\r\n                    ra_c.Append(adj_end_r)\r\n                    if is_x:\r\n                        cp0 = XYZ(near_coord, far_t,     0)\r\n                        cp1 = XYZ(near_coord, adj_end_p, 0)\r\n                    else:\r\n                        cp0 = XYZ(far_t,     near_coord, 0)\r\n                        cp1 = XYZ(adj_end_p, near_coord, 0)\r\n                    try_dim(cp0, cp1, ra_c, dt_wall)\r\n                    break\r\n\r\nrun_group(h_walls, XYZ.BasisX, True)\r\nrun_group(v_walls, XYZ.BasisY, False)\r\n\r\nTransactionManager.Instance.TransactionTaskDone()\r\nOUT = \"完成 | 水平RC牆:{} 垂直RC牆:{}\".format(len(h_walls), len(v_walls))",
