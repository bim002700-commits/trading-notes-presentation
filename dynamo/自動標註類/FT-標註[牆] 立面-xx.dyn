        "60dbfa67-06a0-4a09-aaef-13ba7a5a1d64-0011170b",
        "8a651193-8443-4bfc-862e-04384b8e34a2-00141503",
        "8a651193-8443-4bfc-862e-04384b8e34a2-0014152d",
        "fd4a3767-1009-499e-9c73-45942eb0ff84-001fcb0a"
      ],
      "Id": "83d2f93c3d06417882e84b8cb9fb037f",
      "Inputs": [],
      "Outputs": [
        {
          "Id": "3ae59dcfcc794d67bedf2564f9b17bcb",
          "Name": "Elements",
          "Description": "選取的元素。",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Replication": "Disabled",
      "Description": "從 Revit 文件中選取多個元素。"
    },
    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "import math\r\nimport clr\r\nclr.AddReference('RevitAPI')\r\nclr.AddReference('RevitServices')\r\n\r\nfrom Autodesk.Revit.DB import (\r\n    FilteredElementCollector, DimensionType, Dimension,\r\n    Options, ViewDetailLevel, GeometryInstance, Solid,\r\n    PlanarFace, Line, XYZ, ReferenceArray, Reference,\r\n    BuiltInCategory, BuiltInParameter, LocationCurve,\r\n    UnitUtils, UnitTypeId, Grid\r\n)\r\nfrom RevitServices.Persistence import DocumentManager\r\nfrom RevitServices.Transactions import TransactionManager\r\n\r\ndoc  = DocumentManager.Instance.CurrentDBDocument\r\nview = doc.ActiveView\r\nVIEW_DIR = view.ViewDirection.Normalize()\r\n\r\nraw_elems     = IN[0] if isinstance(IN[0], list) else [IN[0]]\r\nwall_dim_name = IN[1] if IN[1] is not None else \"FT-DIM-WALL(TXT_4mm)\"\r\nvoid_dim_name = IN[2] if IN[2] is not None else \"FT-DIM-VOID(TXT_4mm)\"\r\ndist_outer    = float(IN[3]) if IN[3] is not None else 1000.0  # 上層 Grid 標偏移\r\ndist_inner    = float(IN[4]) if IN[4] is not None else 300.0   # 下層細節標偏移\r\nSIDE_X        = 1 if IN[5] is True else -1\r\nSIDE_Y        = 1 if IN[6] is True else -1\r\n\r\ndef ft(mm):\r\n    return UnitUtils.ConvertToInternalUnits(mm, UnitTypeId.Millimeters)\r\n\r\nD_OUTER  = ft(dist_outer)\r\nD_INNER  = ft(dist_inner)\r\nMIN_SPAN = ft(50)\r\nDOOR_WIN_CATS = {int(BuiltInCategory.OST_Doors), int(BuiltInCategory.OST_Windows)}\r\n\r\ndef unwrap(x):\r\n    return x.InternalElement if hasattr(x, 'InternalElement') else x\r\n\r\ndef safe_type_name(elem):\r\n    try:\r\n        t = doc.GetElement(elem.GetTypeId())\r\n        if t and t.Name: return t.Name\r\n    except: pass\r\n    try:\r\n        n = elem.Name\r\n        if n: return n\r\n    except: pass\r\n    return \"\"\r\n\r\nall_dt = list(FilteredElementCollector(doc).OfClass(DimensionType).ToElements())\r\ndef find_dt(name):\r\n    dt = next((d for d in all_dt if d.get_Parameter(BuiltInParameter.ALL_MODEL_TYPE_NAME).AsString() == name), None)\r\n    return dt or (all_dt[0] if all_dt else None)\r\n\r\ndt_wall = find_dt(wall_dim_name)\r\ndt_void = find_dt(void_dim_name)\r\n\r\nh_walls = []\r\nv_walls = []\r\nfor raw in raw_elems:\r\n    elem = unwrap(raw)\r\n    if elem is None: continue\r\n    try:\r\n        if not elem.IsValidObject: continue\r\n        cat_id = elem.Category.Id.IntegerValue\r\n    except: continue\r\n    if cat_id != int(BuiltInCategory.OST_Walls): continue\r\n    if \"RC\" not in safe_type_name(elem): continue\r\n    try:\r\n        lc = elem.Location\r\n        if isinstance(lc, LocationCurve):\r\n            p0 = lc.Curve.GetEndPoint(0)\r\n            p1 = lc.Curve.GetEndPoint(1)\r\n            if abs(p1.X - p0.X) >= abs(p1.Y - p0.Y):\r\n                h_walls.append(elem)\r\n            else:\r\n                v_walls.append(elem)\r\n        else:\r\n            h_walls.append(elem)\r\n    except:\r\n        h_walls.append(elem)\r\n\r\ndef collect_solid_faces(geo_iter, normal_dir, out, dot_tol=0.99):\r\n    for g_obj in geo_iter:\r\n        parts = [g_obj]\r\n        if isinstance(g_obj, GeometryInstance):\r\n            try: parts = list(g_obj.GetInstanceGeometry())\r\n            except: continue\r\n        for part in parts:\r\n            if isinstance(part, Solid) and part.Volume > 0:\r\n                for face in part.Faces:\r\n                    if isinstance(face, PlanarFace):\r\n                        dot = face.FaceNormal.Normalize().DotProduct(normal_dir)\r\n                        if abs(dot) > dot_tol:\r\n                            out.append((face.Reference, face.Origin.DotProduct(normal_dir)))\r\n\r\ndef get_all_faces_sorted(elem, normal_dir, tol_mm=10, dot_tol=0.99):\r\n    opts = Options()\r\n    opts.ComputeReferences = True\r\n    opts.View = view\r\n    faces = []\r\n    try:\r\n        geo = elem.get_Geometry(opts)\r\n        if geo: collect_solid_faces(geo, normal_dir, faces, dot_tol)\r\n    except: pass\r\n    faces.sort(key=lambda x: x[1])\r\n    tol = ft(tol_mm)\r\n    deduped = []\r\n    for f in faces:\r\n        if not deduped or abs(f[1] - deduped[-1][1]) > tol:\r\n            deduped.append(f)\r\n    return deduped\r\n\r\ndef get_outer_two(faces):\r\n    return [faces[0], faces[-1]] if len(faces) >= 2 else faces\r\n\r\ndef find_face_near(faces, target, tol_mm=200):\r\n    tol = ft(tol_mm)\r\n    best = None\r\n    best_d = tol\r\n    for ref, pos in faces:\r\n        d = abs(pos - target)\r\n        if d < best_d:\r\n            best_d = d\r\n            best = ref\r\n    return best\r\n\r\ndef group_elements(elements, axis, tol=ft(500)):\r\n    groups = []\r\n    for e in elements:\r\n        try: bbox = e.get_BoundingBox(view)\r\n        except: continue\r\n        if not bbox: continue\r\n        pos = ((bbox.Min.Y + bbox.Max.Y) / 2 if axis == 'X'\r\n               else (bbox.Min.X + bbox.Max.X) / 2)\r\n        found = False\r\n        for g in groups:\r\n            if abs(g['pos'] - pos) < tol:\r\n                g['items'].append(e)\r\n                found = True\r\n                break\r\n        if not found:\r\n            groups.append({'pos': pos, 'items': [e]})\r\n    return groups\r\n\r\ndef try_dim(p0, p1, ra, dt):\r\n    if ra.Size < 2: return False\r\n    if p0.DistanceTo(p1) < ft(1): return False\r\n    try:\r\n        d = doc.Create.NewDimension(view, Line.CreateBound(p0, p1), ra)\r\n        if d and dt: d.DimensionType = dt\r\n        return True\r\n    except: return False\r\n\r\nVERT_DIR = XYZ.BasisZ\r\n\r\ndef wall_vertical_span(wall, dot_tol=0.95):\r\n    faces = get_all_faces_sorted(wall, VERT_DIR, tol_mm=5, dot_tol=dot_tol)\r\n    outer = get_outer_two(faces)\r\n    if len(outer) < 2: return None\r\n    z_lo, z_hi = outer[0][1], outer[-1][1]\r\n    if (z_hi - z_lo) < MIN_SPAN: return None\r\n    return z_lo, z_hi, outer[0][0], outer[-1][0]\r\n\r\ndef get_opening_z_refs(wall, all_z_faces, z_lo, z_hi):\r\n    openings = []\r\n    try:\r\n        for ins_id in wall.FindInserts(False, False, False, False):\r\n            ins = doc.GetElement(ins_id)\r\n            if ins is None: continue\r\n            try:\r\n                ins_bbox = ins.get_BoundingBox(None)\r\n                if not ins_bbox: continue\r\n                i_zlo = ins_bbox.Min.Z\r\n                i_zhi = ins_bbox.Max.Z\r\n                if (i_zhi - i_zlo) < MIN_SPAN: continue\r\n                if i_zhi < z_lo or i_zlo > z_hi: continue\r\n                opts = Options()\r\n                opts.ComputeReferences = True\r\n                opts.View = view\r\n                ins_geo = ins.get_Geometry(opts)\r\n                ins_z_faces = []\r\n                if ins_geo:\r\n                    collect_solid_faces(ins_geo, VERT_DIR, ins_z_faces, 0.85)\r\n                if len(ins_z_faces) >= 2:\r\n                    ins_z_faces.sort(key=lambda x: x[1])\r\n                    r_lo = ins_z_faces[0][0]\r\n                    r_hi = ins_z_faces[-1][0]\r\n                else:\r\n                    r_lo = find_face_near(all_z_faces, i_zlo)\r\n                    r_hi = find_face_near(all_z_faces, i_zhi)\r\n                if r_lo and r_hi:\r\n                    openings.append((r_lo, r_hi, i_zlo, i_zhi))\r\n            except: continue\r\n    except: pass\r\n    return openings\r\n\r\ndef collect_grid_refs(horiz_dir, range_lo, range_hi, margin_mm=10000):\r\n    \"\"\"只收集 Grid Reference，用於上層標\"\"\"\r\n    margin = ft(margin_mm)\r\n    refs = []\r\n    try:\r\n        grids = list(FilteredElementCollector(doc).OfClass(Grid).ToElements())\r\n        for grid in grids:\r\n            try:\r\n                curve = grid.Curve\r\n                gp0 = curve.GetEndPoint(0)\r\n                gp1 = curve.GetEndPoint(1)\r\n                pos0 = gp0.X * horiz_dir.X + gp0.Y * horiz_dir.Y\r\n                pos1 = gp1.X * horiz_dir.X + gp1.Y * horiz_dir.Y\r\n                if abs(pos0 - pos1) > ft(500): continue\r\n                pos = (pos0 + pos1) / 2\r\n                if pos < range_lo - margin or pos > range_hi + margin: continue\r\n                opts = Options()\r\n                opts.ComputeReferences = True\r\n                opts.View = view\r\n                geo = grid.get_Geometry(opts)\r\n                if not geo: continue\r\n                for g_obj in geo:\r\n                    try:\r\n                        ref = g_obj.Reference\r\n                        if ref:\r\n                            refs.append((ref, pos))\r\n                            break\r\n                    except: pass\r\n            except: continue\r\n    except: pass\r\n    return refs\r\n\r\nTransactionManager.Instance.EnsureInTransaction(doc)\r\n\r\ndef run_elevation_dims(walls_list, is_x):\r\n    side       = SIDE_X if is_x else SIDE_Y\r\n    group_axis = 'X' if is_x else 'Y'\r\n    long_dir   = XYZ.BasisX if is_x else XYZ.BasisY\r\n    thick_dir  = XYZ.BasisY if is_x else XYZ.BasisX\r\n    groups     = group_elements(walls_list, group_axis)\r\n\r\n    thick_dot = abs(thick_dir.X * VIEW_DIR.X + thick_dir.Y * VIEW_DIR.Y)\r\n    long_dot  = abs(long_dir.X  * VIEW_DIR.X + long_dir.Y  * VIEW_DIR.Y)\r\n    horiz_dir = thick_dir if thick_dot < long_dot else long_dir\r\n\r\n    # 收集所有牆面（下層用）\r\n    wall_refs  = []\r\n    all_z_mids = []\r\n    all_bases  = []\r\n\r\n    for wall in walls_list:\r\n        vsp = wall_vertical_span(wall)\r\n        if not vsp: continue\r\n        z_lo, z_hi = vsp[0], vsp[1]\r\n        all_z_mids.append((z_lo + z_hi) / 2)\r\n\r\n        # ★ 改用垂直邊（Edge）取水平位置\r\n        # 牆的垂直邊包含：牆端面 + 開口邊界，全部有效 Reference\r\n        opts_e = Options()\r\n        opts_e.ComputeReferences = True\r\n        opts_e.View = view\r\n        try:\r\n            geo_e = wall.get_Geometry(opts_e)\r\n            if geo_e:\r\n                for g_obj in geo_e:\r\n                    parts = [g_obj]\r\n                    if isinstance(g_obj, GeometryInstance):\r\n                        try: parts = list(g_obj.GetInstanceGeometry())\r\n                        except: continue\r\n                    for part in parts:\r\n                        if not isinstance(part, Solid) or part.Volume <= 0: continue\r\n                        for edge in part.Edges:\r\n                            try:\r\n                                c = edge.AsCurve()\r\n                                p0 = c.GetEndPoint(0)\r\n                                p1 = c.GetEndPoint(1)\r\n                                dz = abs(p1.Z - p0.Z)\r\n                                dh = math.sqrt((p1.X-p0.X)**2 + (p1.Y-p0.Y)**2)\r\n                                if dz < ft(10) or dh > ft(5): continue\r\n                                z_mid_e = (p0.Z + p1.Z) / 2\r\n                                if z_mid_e < z_lo - ft(50): continue\r\n                                if z_mid_e > z_hi + ft(50): continue\r\n                                mid_x = (p0.X + p1.X) / 2\r\n                                mid_y = (p0.Y + p1.Y) / 2\r\n                                pos = mid_x * horiz_dir.X + mid_y * horiz_dir.Y\r\n                                ref = edge.Reference\r\n                                if ref:\r\n                                    wall_refs.append((ref, pos))\r\n                            except: continue\r\n        except: pass\r\n\r\n        bb = wall.get_BoundingBox(view)\r\n        if bb:\r\n            if is_x:\r\n                all_bases.append(bb.Max.Y if side == 1 else bb.Min.Y)\r\n            else:\r\n                all_bases.append(bb.Max.X if side == 1 else bb.Min.X)\r\n\r\n    if len(wall_refs) >= 2 and all_z_mids:\r\n        positions = [p for _, p in wall_refs]\r\n        range_lo  = min(positions)\r\n        range_hi  = max(positions)\r\n        z_mid     = sum(all_z_mids) / len(all_z_mids)\r\n        base      = max(all_bases) if side == 1 else min(all_bases)\r\n\r\n        # ══ 下層：牆面＋開口（不含 Grid）══\r\n        inner_refs = list(wall_refs)\r\n        inner_refs.sort(key=lambda x: x[1])\r\n        deduped_inner = [inner_refs[0]]\r\n        for ref, pos in inner_refs[1:]:\r\n            if abs(pos - deduped_inner[-1][1]) > ft(50):\r\n                deduped_inner.append((ref, pos))\r\n        if len(deduped_inner) >= 2:\r\n            nc_inner = base + side * D_INNER\r\n            ra = ReferenceArray()\r\n            for ref, _ in deduped_inner: ra.Append(ref)\r\n            lo = deduped_inner[0][1]\r\n            hi = deduped_inner[-1][1]\r\n            if is_x:\r\n                try_dim(XYZ(nc_inner, lo, z_mid), XYZ(nc_inner, hi, z_mid), ra, dt_wall)\r\n            else:\r\n                try_dim(XYZ(lo, nc_inner, z_mid), XYZ(hi, nc_inner, z_mid), ra, dt_wall)\r\n\r\n        # ══ 上層：Grid 到 Grid ══\r\n        grid_refs = collect_grid_refs(horiz_dir, range_lo, range_hi)\r\n        if len(grid_refs) >= 2:\r\n            grid_refs.sort(key=lambda x: x[1])\r\n            deduped_grid = [grid_refs[0]]\r\n            for ref, pos in grid_refs[1:]:\r\n                if abs(pos - deduped_grid[-1][1]) > ft(50):\r\n                    deduped_grid.append((ref, pos))\r\n            if len(deduped_grid) >= 2:\r\n                nc_outer = base + side * D_OUTER\r\n                ra_g = ReferenceArray()\r\n                for ref, _ in deduped_grid: ra_g.Append(ref)\r\n                lo_g = deduped_grid[0][1]\r\n                hi_g = deduped_grid[-1][1]\r\n                if is_x:\r\n                    try_dim(XYZ(nc_outer, lo_g, z_mid), XYZ(nc_outer, hi_g, z_mid), ra_g, dt_wall)\r\n                else:\r\n                    try_dim(XYZ(lo_g, nc_outer, z_mid), XYZ(hi_g, nc_outer, z_mid), ra_g, dt_wall)\r\n\r\n    # ══ 縱向標（開口）══\r\n    for group in groups:\r\n        items = group['items']\r\n        bboxes = [i.get_BoundingBox(view) for i in items]\r\n        bboxes = [b for b in bboxes if b]\r\n        if not bboxes: continue\r\n        if is_x:\r\n            base_coord = (max(b.Max.Y for b in bboxes) if side == 1\r\n                          else min(b.Min.Y for b in bboxes))\r\n        else:\r\n            base_coord = (max(b.Max.X for b in bboxes) if side == 1\r\n                          else min(b.Min.X for b in bboxes))\r\n        near_coord = base_coord + side * D_INNER\r\n\r\n        for wall in items:\r\n            bbox = wall.get_BoundingBox(view)\r\n            if not bbox: continue\r\n            vsp = wall_vertical_span(wall)\r\n            if not vsp: continue\r\n            z_lo, z_hi, ref_zlo, ref_zhi = vsp\r\n            all_z_faces = get_all_faces_sorted(wall, VERT_DIR, tol_mm=5, dot_tol=0.95)\r\n            openings = get_opening_z_refs(wall, all_z_faces, z_lo, z_hi)\r\n            if not openings: continue\r\n            z_refs = [(ref_zlo, z_lo)]\r\n            for r_lo_o, r_hi_o, z_lo_o, z_hi_o in openings:\r\n                z_refs.append((r_lo_o, z_lo_o))\r\n                z_refs.append((r_hi_o, z_hi_o))\r\n            z_refs.append((ref_zhi, z_hi))\r\n            z_refs.sort(key=lambda x: x[1])\r\n            deduped_z = [z_refs[0]]\r\n            for ref, z in z_refs[1:]:\r\n                if abs(z - deduped_z[-1][1]) > ft(50):\r\n                    deduped_z.append((ref, z))\r\n            if len(deduped_z) >= 2:\r\n                ra_z = ReferenceArray()\r\n                for ref, _ in deduped_z: ra_z.Append(ref)\r\n                if is_x:\r\n                    x_mid = (bbox.Min.X + bbox.Max.X) / 2\r\n                    try_dim(XYZ(x_mid, near_coord, deduped_z[0][1]),\r\n                            XYZ(x_mid, near_coord, deduped_z[-1][1]), ra_z, dt_wall)\r\n                else:\r\n                    y_mid = (bbox.Min.Y + bbox.Max.Y) / 2\r\n                    try_dim(XYZ(near_coord, y_mid, deduped_z[0][1]),\r\n                            XYZ(near_coord, y_mid, deduped_z[-1][1]), ra_z, dt_wall)\r\n            for r_lo_o, r_hi_o, z_lo_o, z_hi_o in openings:\r\n                if (z_hi_o - z_lo_o) < MIN_SPAN: continue\r\n                ra_v = ReferenceArray()\r\n                ra_v.Append(r_lo_o)\r\n                ra_v.Append(r_hi_o)\r\n                if is_x:\r\n                    x_mid = (bbox.Min.X + bbox.Max.X) / 2\r\n                    try_dim(XYZ(x_mid, near_coord, z_lo_o),\r\n                            XYZ(x_mid, near_coord, z_hi_o), ra_v, dt_void)\r\n                else:\r\n                    y_mid = (bbox.Min.Y + bbox.Max.Y) / 2\r\n                    try_dim(XYZ(near_coord, y_mid, z_lo_o),\r\n                            XYZ(near_coord, y_mid, z_hi_o), ra_v, dt_void)\r\n\r\nrun_elevation_dims(h_walls, is_x=True)\r\nrun_elevation_dims(v_walls, is_x=False)\r\nTransactionManager.Instance.TransactionTaskDone()\r\n\r\nOUT = \"完成 | H:{} V:{}\".format(len(h_walls), len(v_walls))",
      "Engine": "CPython3",
