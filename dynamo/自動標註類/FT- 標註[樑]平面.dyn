        "d88fc885-b6f9-4f08-8f52-5b4725a29b60-001fc425",
        "fd4a3767-1009-499e-9c73-45942eb0ff84-001fcb0a",
        "9913e6e9-d6f1-4ef5-9e33-73b92aca5774-001fd58b",
        "5b3fa066-3923-42c1-a7ec-9cad2f0e8617-00201c15",
        "5e83d580-4c8c-40bf-8174-167b09f59024-0020233c",
        "b181a8d4-4a69-49c2-9f98-753cbb4beaa2-002026cc",
        "2f63adc0-1512-4efd-a0cf-c49aaf851e9c-00202e43",
        "07ae3014-8fed-4986-b009-1abc84f6f30c-0020b172",
        "07ae3014-8fed-4986-b009-1abc84f6f30c-0020b19c",
        "e4b3f972-04f3-44b4-a701-6d57cef0a7b6-0021a363",
        "763b327b-82e0-4e63-8fb4-daffd7a125a1-0021cb77",
        "69c9732e-b82f-4a54-ab89-d39e8f07549d-002600cc",
        "69c9732e-b82f-4a54-ab89-d39e8f07549d-00260432",
        "69c9732e-b82f-4a54-ab89-d39e8f07549d-00260434",
        "69c9732e-b82f-4a54-ab89-d39e8f07549d-00260435",
        "69c9732e-b82f-4a54-ab89-d39e8f07549d-00260436",
        "69c9732e-b82f-4a54-ab89-d39e8f07549d-0026043a",
        "69c9732e-b82f-4a54-ab89-d39e8f07549d-0026043b",
        "69c9732e-b82f-4a54-ab89-d39e8f07549d-0026043c",
        "69c9732e-b82f-4a54-ab89-d39e8f07549d-0026043d"
      ],
      "Id": "9b3a98c2baa94ebe86a4bb71f534300d",
      "Inputs": [],
      "Outputs": [
        {
          "Id": "3f10bbac8d554b93bf5526513d2035ff",
          "Name": "Elements",
          "Description": "選取的元素。",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Replication": "Disabled",
      "Description": "從 Revit 文件中選取多個元素。"
    },
    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "import clr\r\nclr.AddReference('RevitAPI')\r\nclr.AddReference('RevitServices')\r\n\r\nfrom Autodesk.Revit.DB import Grid as RevitGrid\r\nfrom Autodesk.Revit.DB import (\r\n    FilteredElementCollector, DimensionType, Options,\r\n    GeometryInstance, Solid, PlanarFace, Line, XYZ,\r\n    ReferenceArray, Reference, BuiltInCategory, BuiltInParameter,\r\n    UnitUtils, UnitTypeId\r\n)\r\n\r\nfrom RevitServices.Persistence import DocumentManager\r\nfrom RevitServices.Transactions import TransactionManager\r\n\r\ndoc  = DocumentManager.Instance.CurrentDBDocument\r\nview = doc.ActiveView\r\n\r\n# ─── 輸入 ───────────────────────────────────────────────────────────────────────\r\nraw     = IN[0] if isinstance(IN[0], list) else [IN[0]]\r\ndname   = IN[1]\r\nD_FAR   = UnitUtils.ConvertToInternalUnits(float(IN[2] or 400), UnitTypeId.Millimeters)\r\nD_NEAR  = UnitUtils.ConvertToInternalUnits(float(IN[3] or 50),  UnitTypeId.Millimeters)\r\nMIN_LEN = UnitUtils.ConvertToInternalUnits(float(IN[4] or 500), UnitTypeId.Millimeters)\r\nSX = 1.0 if IN[5] else -1.0\r\nSY = 1.0 if IN[6] else -1.0\r\nPAD = UnitUtils.ConvertToInternalUnits(30.0, UnitTypeId.Millimeters)\r\n\r\ndef mm(v):\r\n    return UnitUtils.ConvertToInternalUnits(v, UnitTypeId.Millimeters)\r\n\r\ndef uw(x):\r\n    return x.InternalElement if hasattr(x, 'InternalElement') else x\r\n\r\n# ─── 標註類型（雙重備援） ────────────────────────────────────────────────────────\r\ndim_type = None\r\nfor dt in FilteredElementCollector(doc).OfClass(DimensionType).WhereElementIsElementType():\r\n    try:\r\n        if dt.Name == dname:\r\n            dim_type = dt\r\n            break\r\n    except:\r\n        continue\r\nif dim_type is None:\r\n    for dt in FilteredElementCollector(doc).OfClass(DimensionType).WhereElementIsElementType():\r\n        try:\r\n            p = dt.get_Parameter(BuiltInParameter.ALL_MODEL_TYPE_NAME)\r\n            if p is not None and p.AsString() == dname:\r\n                dim_type = dt\r\n                break\r\n        except:\r\n            continue\r\nif dim_type is None:\r\n    OUT = [[], [\"找不到標註類型: \" + str(dname)]]\r\n    raise Exception(\"DimensionType not found: \" + str(dname))\r\n\r\n# ─── 分類元素 ─────────────────────────────────────────────────────────────────\r\nbeams_x, beams_y = [], []\r\ngrids_h, grids_v = [], []\r\n\r\nfor item in raw:\r\n    e = uw(item)\r\n    if e is None:\r\n        continue\r\n\r\n    # ✅ Grid 用 isinstance + e.Curve 直接讀取（不用 Location.Curve）\r\n    if isinstance(e, RevitGrid):\r\n        try:\r\n            c  = e.Curve          # Grid 專屬屬性，比 Location.Curve 可靠\r\n            p0 = c.GetEndPoint(0)\r\n            p1 = c.GetEndPoint(1)\r\n            if abs(p1.X - p0.X) > abs(p1.Y - p0.Y):\r\n                grids_h.append(e)\r\n            else:\r\n                grids_v.append(e)\r\n        except:\r\n            pass\r\n        continue\r\n\r\n    # 結構框架（樑）\r\n    cat = e.Category\r\n    if cat is None:\r\n        continue\r\n    if cat.Id.IntegerValue != int(BuiltInCategory.OST_StructuralFraming):\r\n        continue\r\n    loc = e.Location\r\n    if not hasattr(loc, 'Curve'):\r\n        continue\r\n    c = loc.Curve\r\n    if c.Length < MIN_LEN:\r\n        continue\r\n    p0 = c.GetEndPoint(0)\r\n    p1 = c.GetEndPoint(1)\r\n    if abs(p1.X - p0.X) > abs(p1.Y - p0.Y):\r\n        beams_x.append(e)\r\n    else:\r\n        beams_y.append(e)\r\n\r\n# ─── 取得截面兩側面參考 ──────────────────────────────────────────────────────────\r\ndef get_face_refs(beam, use_y):\r\n    opt = Options()\r\n    opt.ComputeReferences        = True\r\n    opt.IncludeNonVisibleObjects = False\r\n    opt.View = view\r\n\r\n    candidates = []\r\n    for g in beam.get_Geometry(opt):\r\n        solids = []\r\n        if isinstance(g, GeometryInstance):\r\n            try:\r\n                for sg in g.GetInstanceGeometry():\r\n                    if isinstance(sg, Solid) and sg.Volume > 1e-9:\r\n                        solids.append(sg)\r\n            except:\r\n                pass\r\n        elif isinstance(g, Solid) and g.Volume > 1e-9:\r\n            solids.append(g)\r\n\r\n        for solid in solids:\r\n            for face in solid.Faces:\r\n                if not isinstance(face, PlanarFace):\r\n                    continue\r\n                fn  = face.FaceNormal\r\n                dot = abs(fn.Y) if use_y else abs(fn.X)\r\n                if dot < 0.9:\r\n                    continue\r\n                try:\r\n                    ref = face.Reference\r\n                except:\r\n                    continue\r\n                if ref is None:\r\n                    continue\r\n                pos = face.Origin.Y if use_y else face.Origin.X\r\n                candidates.append((pos, ref))\r\n\r\n    if len(candidates) < 2:\r\n        return []\r\n    candidates.sort(key=lambda x: x[0])\r\n    return [candidates[0], candidates[-1]]\r\n\r\n# ─── 找距樑中心最近的柱線（不依賴截面範圍） ─────────────────────────────────────\r\ndef find_nearest_grid(grids, use_y, center_pos):\r\n    best   = None\r\n    best_d = float('inf')\r\n    for g in grids:\r\n        try:\r\n            c = g.Curve           # ✅ Grid.Curve 直接屬性\r\n        except:\r\n            try:\r\n                c = g.Location.Curve\r\n            except:\r\n                continue\r\n        p0  = c.GetEndPoint(0)\r\n        p1  = c.GetEndPoint(1)\r\n        pos = (p0.Y + p1.Y) / 2.0 if use_y else (p0.X + p1.X) / 2.0\r\n        d   = abs(pos - center_pos)\r\n        if d < best_d:\r\n            best_d = d\r\n            best   = (pos, Reference(g))\r\n    return [best] if best is not None else []\r\n\r\n# ─── 建立標註（過濾 0 段） ────────────────────────────────────────────────────────\r\ndef make_dim(refs_list, line):\r\n    if len(refs_list) < 2:\r\n        return None\r\n    # 過濾相鄰位置太近的參考（防止 0 尺寸）\r\n    min_seg = mm(1)\r\n    filtered = [refs_list[0]]\r\n    for item in refs_list[1:]:\r\n        if abs(item[0] - filtered[-1][0]) >= min_seg:\r\n            filtered.append(item)\r\n    if len(filtered) < 2:\r\n        return None\r\n    ra = ReferenceArray()\r\n    for _, ref in filtered:\r\n        ra.Append(ref)\r\n    try:\r\n        return doc.Create.NewDimension(view, line, ra, dim_type)\r\n    except Exception as ex:\r\n        return \"ERR:\" + str(ex)\r\n\r\n# ─── 跨度重疊分組 ────────────────────────────────────────────────────────────────\r\ndef group_by_span_overlap(beams, get_lo_hi_cx):\r\n    info  = [(b,) + get_lo_hi_cx(b) for b in beams]\r\n    used  = [False] * len(info)\r\n    groups = []\r\n    for i, (b, lo, hi, cx) in enumerate(info):\r\n        if used[i]:\r\n            continue\r\n        grp = [info[i]]\r\n        used[i] = True\r\n        for j, (b2, lo2, hi2, cx2) in enumerate(info):\r\n            if used[j]:\r\n                continue\r\n            if lo2 < hi and lo < hi2:\r\n                grp.append(info[j])\r\n                used[j] = True\r\n        groups.append(grp)\r\n    return groups\r\n\r\ndef x_lo_hi_cx(b):\r\n    c  = b.Location.Curve\r\n    x0 = c.GetEndPoint(0).X\r\n    x1 = c.GetEndPoint(1).X\r\n    return (min(x0,x1), max(x0,x1), (x0+x1)/2.0)\r\n\r\ndef y_lo_hi_cy(b):\r\n    c  = b.Location.Curve\r\n    y0 = c.GetEndPoint(0).Y\r\n    y1 = c.GetEndPoint(1).Y\r\n    return (min(y0,y1), max(y0,y1), (y0+y1)/2.0)\r\n\r\n# ─── 主程式 ───────────────────────────────────────────────────────────────────────\r\nresults, errors = [], []\r\nTransactionManager.Instance.EnsureInTransaction(doc)\r\n\r\n# ══ X向樑：BasisY面 + 水平柱線 → 垂直標註線 ══════════════════════════════════════\r\nfor beam in beams_x:\r\n    c  = beam.Location.Curve\r\n    cx = (c.GetEndPoint(0).X + c.GetEndPoint(1).X) / 2.0\r\n\r\n    fr = get_face_refs(beam, use_y=True)\r\n    if len(fr) < 2:\r\n        errors.append(\"X-beam %d: no Y-faces\" % beam.Id.IntegerValue)\r\n        continue\r\n\r\n    y_lo = fr[0][0]\r\n    y_hi = fr[-1][0]\r\n    cy_beam = (y_lo + y_hi) / 2.0\r\n    g_in = find_nearest_grid(grids_h, use_y=True,  center_pos=cy_beam)\r\n\r\n    x_line = cx + SX * D_NEAR\r\n    line   = Line.CreateBound(XYZ(x_line, y_lo - PAD, 0.0),\r\n                              XYZ(x_line, y_hi + PAD, 0.0))\r\n    d = make_dim([fr[0]] + g_in + [fr[-1]], line)\r\n    (results if d and not isinstance(d, str) else errors).append(d)\r\n\r\nfor grp in group_by_span_overlap(beams_x, x_lo_hi_cx):\r\n    if len(grp) < 2:\r\n        continue\r\n    all_faces, cx_list = [], []\r\n    for (b, lo, hi, cx) in grp:\r\n        fr = get_face_refs(b, use_y=True)\r\n        if len(fr) >= 2:\r\n            all_faces.extend(fr)\r\n        cx_list.append(cx)\r\n    if len(all_faces) < 4:\r\n        continue\r\n    all_faces.sort(key=lambda x: x[0])\r\n    gcx   = sum(cx_list) / len(cx_list)\r\n    x_out = gcx + SX * D_FAR\r\n    line  = Line.CreateBound(XYZ(x_out, all_faces[0][0] - PAD, 0.0),\r\n                             XYZ(x_out, all_faces[-1][0] + PAD, 0.0))\r\n    d = make_dim(all_faces, line)\r\n    (results if d and not isinstance(d, str) else errors).append(d)\r\n\r\n# ══ Y向樑：BasisX面 + 垂直柱線 → 水平標註線 ══════════════════════════════════════\r\nfor beam in beams_y:\r\n    c  = beam.Location.Curve\r\n    cy = (c.GetEndPoint(0).Y + c.GetEndPoint(1).Y) / 2.0\r\n\r\n    fr = get_face_refs(beam, use_y=False)\r\n    if len(fr) < 2:\r\n        errors.append(\"Y-beam %d: no X-faces\" % beam.Id.IntegerValue)\r\n        continue\r\n\r\n    x_lo = fr[0][0]\r\n    x_hi = fr[-1][0]\r\n    cx_beam = (x_lo + x_hi) / 2.0\r\n    g_in = find_nearest_grid(grids_v, use_y=False, center_pos=cx_beam)\r\n\r\n    y_line = cy + SY * D_NEAR\r\n    line   = Line.CreateBound(XYZ(x_lo - PAD, y_line, 0.0),\r\n                              XYZ(x_hi + PAD, y_line, 0.0))\r\n    d = make_dim([fr[0]] + g_in + [fr[-1]], line)\r\n    (results if d and not isinstance(d, str) else errors).append(d)\r\n\r\nfor grp in group_by_span_overlap(beams_y, y_lo_hi_cy):\r\n    if len(grp) < 2:\r\n        continue\r\n    all_faces, cy_list = [], []\r\n    for (b, lo, hi, cy) in grp:\r\n        fr = get_face_refs(b, use_y=False)\r\n        if len(fr) >= 2:\r\n            all_faces.extend(fr)\r\n        cy_list.append(cy)\r\n    if len(all_faces) < 4:\r\n        continue\r\n    all_faces.sort(key=lambda x: x[0])\r\n    gcy   = sum(cy_list) / len(cy_list)\r\n    y_out = gcy + SY * D_FAR\r\n    line  = Line.CreateBound(XYZ(all_faces[0][0] - PAD, y_out, 0.0),\r\n                             XYZ(all_faces[-1][0] + PAD, y_out, 0.0))\r\n    d = make_dim(all_faces, line)\r\n    (results if d and not isinstance(d, str) else errors).append(d)\r\n\r\nerrors.append(\"grids_h=%d  grids_v=%d  beams_x=%d  beams_y=%d\"\r\n              % (len(grids_h), len(grids_v), len(beams_x), len(beams_y)))\r\n\r\nTransactionManager.Instance.TransactionTaskDone()\r\nOUT = [results, errors]",
      "Engine": "CPython3",
      "EngineName": "CPython3",
      "VariableInputPorts": true,
