    {
      "ConcreteType": "CoreNodeModels.Input.StringInput, CoreNodeModels",
      "Id": "c1bfc8de47274a9794f91c7d13613569",
      "NodeType": "StringInputNode",
      "Inputs": [],
      "Outputs": [
        {
          "Id": "a577e59e739247dea42c2209369fcf38",
          "Name": "",
          "Description": "String",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Replication": "Disabled",
      "Description": "建立一個字串。",
      "InputValue": "FT-DIM-BEAM(TXT_4.0mm)"
    },
    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "import clr\r\nclr.AddReference('RevitAPI')\r\nclr.AddReference('RevitServices')\r\nfrom Autodesk.Revit.DB import Grid as RevitGrid\r\nfrom Autodesk.Revit.DB import (\r\n    FilteredElementCollector, DimensionType, Options,\r\n    GeometryInstance, Solid, PlanarFace, Line, XYZ,\r\n    ReferenceArray, Reference, BuiltInCategory, BuiltInParameter,\r\n    UnitUtils, UnitTypeId, Level\r\n)\r\nfrom RevitServices.Persistence import DocumentManager\r\nfrom RevitServices.Transactions import TransactionManager\r\nimport unicodedata\r\n\r\ndoc  = DocumentManager.Instance.CurrentDBDocument\r\nview = doc.ActiveView\r\n\r\nraw     = IN[0] if isinstance(IN[0], list) else [IN[0]]\r\ndname   = IN[1]\r\nD_FAR   = UnitUtils.ConvertToInternalUnits(float(IN[2] or 400), UnitTypeId.Millimeters)\r\nD_NEAR  = UnitUtils.ConvertToInternalUnits(float(IN[3] or 50),  UnitTypeId.Millimeters)\r\nMIN_LEN = UnitUtils.ConvertToInternalUnits(float(IN[4] or 500), UnitTypeId.Millimeters)\r\nSU = 1.0 if IN[5] else -1.0\r\nSZ = 1.0 if IN[6] else -1.0\r\nPAD = UnitUtils.ConvertToInternalUnits(30.0, UnitTypeId.Millimeters)\r\n\r\ndef mm(v): return UnitUtils.ConvertToInternalUnits(v, UnitTypeId.Millimeters)\r\ndef uw(x): return x.InternalElement if hasattr(x, 'InternalElement') else x\r\n\r\nEXCLUDE_KW = [\r\n    unicodedata.normalize('NFC', \"\\u4e0a\\u4e0b\\u589e\\u6253\"),\r\n    unicodedata.normalize('NFC', \"\\u5074\\u589e\\u6253\"),\r\n]\r\n\r\nvright = view.RightDirection\r\nvdir   = view.ViewDirection\r\nview_d = view.Origin.X * vdir.X + view.Origin.Y * vdir.Y\r\n\r\ndef make_pt(u, z):\r\n    return XYZ(vright.X*u + vdir.X*view_d, vright.Y*u + vdir.Y*view_d, z)\r\n\r\ndef get_u(pt):\r\n    return pt.X * vright.X + pt.Y * vright.Y\r\n\r\nall_levels = list(FilteredElementCollector(doc).OfClass(Level))\r\n\r\ndef get_nearest_level_ref(z_top):\r\n    best, best_d = None, float('inf')\r\n    for lv in all_levels:\r\n        dz = lv.Elevation - z_top\r\n        if dz < -mm(10):  continue\r\n        if dz >  mm(500): continue\r\n        d = abs(dz)\r\n        if d < best_d:\r\n            best_d = d; best = (lv.Elevation, Reference(lv))\r\n    return best\r\n\r\nelev_grids = []\r\nfor g in FilteredElementCollector(doc).OfClass(RevitGrid):\r\n    try:\r\n        c  = g.Curve\r\n        p0 = c.GetEndPoint(0); p1 = c.GetEndPoint(1)\r\n        dx = p1.X - p0.X; dy = p1.Y - p0.Y\r\n        hl = (dx*dx + dy*dy) ** 0.5\r\n        if hl < 1e-9: continue\r\n        if abs(dx/hl * vdir.X + dy/hl * vdir.Y) > 0.7:\r\n            elev_grids.append(g)\r\n    except: pass\r\n\r\nerrors = []\r\nerrors.append(\"vright=(%.2f,%.2f) vdir=(%.2f,%.2f) grids=%d lvl=%d\" % (\r\n    vright.X, vright.Y, vdir.X, vdir.Y, len(elev_grids), len(all_levels)))\r\n\r\ndim_type = None\r\nfor dt in FilteredElementCollector(doc).OfClass(DimensionType).WhereElementIsElementType():\r\n    try:\r\n        if dt.Name == dname: dim_type = dt; break\r\n    except: continue\r\nif dim_type is None:\r\n    for dt in FilteredElementCollector(doc).OfClass(DimensionType).WhereElementIsElementType():\r\n        try:\r\n            p = dt.get_Parameter(BuiltInParameter.ALL_MODEL_TYPE_NAME)\r\n            if p is not None and p.AsString() == dname: dim_type = dt; break\r\n        except: continue\r\nif dim_type is None:\r\n    avail = sorted([dt.Name for dt in\r\n                    FilteredElementCollector(doc).OfClass(DimensionType).WhereElementIsElementType()])\r\n    OUT = [[], [\"找不到: «%s»\" % dname] + avail]; raise Exception(\"DimensionType not found\")\r\n\r\nACCEPT_CATS = { int(BuiltInCategory.OST_StructuralFraming) }\r\n\r\nbeams = []\r\nfor item in raw:\r\n    e = uw(item)\r\n    if e is None: continue\r\n    cat = e.Category\r\n    if cat is None or cat.Id.IntegerValue not in ACCEPT_CATS:\r\n        errors.append(\"ID=%d skip Cat=%s\" % (e.Id.IntegerValue, cat.Name if cat else \"無\")); continue\r\n    raw_strs = []\r\n    try:\r\n        sym = e.Symbol; fn = sym.Family.Name; sn = sym.Name\r\n        if fn: raw_strs.append(fn)\r\n        if sn: raw_strs.append(sn)\r\n    except: pass\r\n    try:\r\n        en = e.Name\r\n        if en: raw_strs.append(en)\r\n    except: pass\r\n    try:\r\n        p = e.get_Parameter(BuiltInParameter.ELEM_FAMILY_AND_TYPE_PARAM)\r\n        if p:\r\n            vs = p.AsValueString()\r\n            if vs: raw_strs.append(vs)\r\n    except: pass\r\n    combined_norm = unicodedata.normalize('NFC', \" \".join(raw_strs))\r\n    if any(kw in combined_norm for kw in EXCLUDE_KW):\r\n        errors.append(\"ID=%d skip EXCLUDED\" % e.Id.IntegerValue); continue\r\n    loc = e.Location\r\n    if loc is None or not hasattr(loc, 'Curve'):\r\n        errors.append(\"ID=%d skip 無曲線\" % e.Id.IntegerValue); continue\r\n    try:\r\n        ep0 = loc.Curve.GetEndPoint(0); ep1 = loc.Curve.GetEndPoint(1)\r\n        ddx = ep1.X - ep0.X; ddy = ep1.Y - ep0.Y\r\n        ddl_h = (ddx*ddx + ddy*ddy) ** 0.5\r\n        ddl   = (ddx*ddx + ddy*ddy + (ep1.Z-ep0.Z)**2) ** 0.5\r\n    except:\r\n        errors.append(\"ID=%d skip 端點錯誤\" % e.Id.IntegerValue); continue\r\n    if ddl < MIN_LEN:\r\n        errors.append(\"ID=%d skip 短\" % e.Id.IntegerValue); continue\r\n    if ddl_h < mm(50):\r\n        errors.append(\"ID=%d skip 垂直\" % e.Id.IntegerValue); continue\r\n    errors.append(\"ID=%d PASS [%s]\" % (e.Id.IntegerValue, combined_norm[:25]))\r\n    beams.append(e)\r\n\r\nerrors.append(\"=== beams=%d  grids=%d ===\" % (len(beams), len(elev_grids)))\r\n\r\ndef get_faces(beam, use_z):\r\n    opt = Options(); opt.ComputeReferences = True\r\n    opt.IncludeNonVisibleObjects = False; opt.View = view\r\n    cands = []\r\n    for g in beam.get_Geometry(opt):\r\n        solids = []\r\n        if isinstance(g, GeometryInstance):\r\n            try:\r\n                for sg in g.GetInstanceGeometry():\r\n                    if isinstance(sg, Solid) and sg.Volume > 1e-9: solids.append(sg)\r\n            except: pass\r\n        elif isinstance(g, Solid) and g.Volume > 1e-9:\r\n            solids.append(g)\r\n        for solid in solids:\r\n            for face in solid.Faces:\r\n                if not isinstance(face, PlanarFace): continue\r\n                fn = face.FaceNormal\r\n                score = abs(fn.Z) if use_z else abs(fn.X*vright.X + fn.Y*vright.Y)\r\n                if score < 0.9: continue\r\n                try:   ref = face.Reference\r\n                except: continue\r\n                if ref is None: continue\r\n                pos = face.Origin.Z if use_z else get_u(face.Origin)\r\n                cands.append((pos, ref))\r\n    if len(cands) < 2: return []\r\n    cands.sort(key=lambda x: x[0])\r\n    return [cands[0], cands[-1]]\r\n\r\ndef make_dim(refs_list, line):\r\n    if len(refs_list) < 2: return None\r\n    filtered = [refs_list[0]]\r\n    for item in refs_list[1:]:\r\n        if abs(item[0] - filtered[-1][0]) >= mm(1): filtered.append(item)\r\n    if len(filtered) < 2: return None\r\n    ra = ReferenceArray()\r\n    for _, ref in filtered: ra.Append(ref)\r\n    try:   return doc.Create.NewDimension(view, line, ra, dim_type)\r\n    except Exception as ex: return \"ERR:\" + str(ex)\r\n\r\nresults = []\r\nTransactionManager.Instance.EnsureInTransaction(doc)\r\n\r\nfor beam in beams:\r\n    c  = beam.Location.Curve\r\n    cu = (get_u(c.GetEndPoint(0)) + get_u(c.GetEndPoint(1))) / 2.0\r\n    cz = (c.GetEndPoint(0).Z   + c.GetEndPoint(1).Z)   / 2.0\r\n    zf = get_faces(beam, use_z=True)\r\n    ef = get_faces(beam, use_z=False)   # ← 移到最前，縱向也用得到\r\n\r\n    # 橫向樑面 u 範圍\r\n    if len(ef) >= 2:\r\n        u_lo = ef[0][0]; u_hi = ef[-1][0]\r\n    else:\r\n        u_lo = cu; u_hi = cu\r\n\r\n    # 樓層線（縱向用）\r\n    lv = get_nearest_level_ref(zf[-1][0]) if len(zf) >= 2 else None\r\n\r\n    # 橫向標註基準 Z（樑外側面）\r\n    if len(zf) >= 2:\r\n        z_h_base = zf[0][0] if SZ < 0 else zf[-1][0]\r\n    else:\r\n        z_h_base = cz\r\n    z_in  = z_h_base + SZ * D_NEAR\r\n    z_out = z_h_base + SZ * D_FAR\r\n\r\n    # ── ① 縱向：以樑外側面起算，保持一致間距 ──────────────────────\r\n    # SU < 0 (←) → 左側面往左  SU > 0 (→) → 右側面往右\r\n    u_line = (u_lo - D_NEAR) if SU < 0 else (u_hi + D_NEAR)\r\n\r\n    if len(zf) >= 2:\r\n        v_refs = list(zf) + ([lv] if lv else [])\r\n        v_refs.sort(key=lambda x: x[0])\r\n        ln = Line.CreateBound(make_pt(u_line, v_refs[0][0]-PAD),\r\n                              make_pt(u_line, v_refs[-1][0]+PAD))\r\n        d = make_dim(v_refs, ln)\r\n        (results if d and not isinstance(d, str) else errors).append(d)\r\n    else:\r\n        errors.append(\"Beam %d: 頂底面未找到\" % beam.Id.IntegerValue)\r\n\r\n    # ── ② 橫向 ───────────────────────────────────────────────────\r\n    if len(ef) < 2:\r\n        errors.append(\"Beam %d: 水平面未找到\" % beam.Id.IntegerValue)\r\n        continue\r\n\r\n    inner = list(ef); has_grid = False\r\n    for g in elev_grids:\r\n        try:\r\n            gc  = g.Curve\r\n            u_g = (get_u(gc.GetEndPoint(0)) + get_u(gc.GetEndPoint(1))) / 2.0\r\n            if u_lo - mm(5) <= u_g <= u_hi + mm(5):\r\n                inner.append((u_g, Reference(g))); has_grid = True\r\n        except: pass\r\n\r\n    inner.sort(key=lambda x: x[0])\r\n    inner2 = [inner[0]]\r\n    for f in inner[1:]:\r\n        if abs(f[0] - inner2[-1][0]) >= mm(1): inner2.append(f)\r\n\r\n    if has_grid and len(inner2) >= 3:\r\n        ln = Line.CreateBound(make_pt(inner2[0][0]-PAD, z_in),\r\n                              make_pt(inner2[-1][0]+PAD, z_in))\r\n        d = make_dim(inner2, ln)\r\n        (results if d and not isinstance(d, str) else errors).append(d)\r\n        outer = [inner2[0], inner2[-1]]\r\n        if abs(outer[-1][0]-outer[0][0]) > mm(1):\r\n            ln = Line.CreateBound(make_pt(outer[0][0]-PAD, z_out),\r\n                                  make_pt(outer[-1][0]+PAD, z_out))\r\n            d = make_dim(outer, ln)\r\n            (results if d and not isinstance(d, str) else errors).append(d)\r\n    else:\r\n        if abs(u_hi - u_lo) > mm(1):\r\n            ln = Line.CreateBound(make_pt(u_lo-PAD, z_in),\r\n                                  make_pt(u_hi+PAD, z_in))\r\n            d = make_dim(ef, ln)\r\n            (results if d and not isinstance(d, str) else errors).append(d)\r\n\r\nTransactionManager.Instance.TransactionTaskDone()\r\nOUT = [results, errors]",
      "Engine": "CPython3",
