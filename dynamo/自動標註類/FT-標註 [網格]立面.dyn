  "Nodes": [
    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "import clr\r\nclr.AddReference('RevitAPI')\r\nfrom Autodesk.Revit.DB import *\r\nclr.AddReference('RevitServices')\r\nfrom RevitServices.Persistence import DocumentManager\r\nfrom RevitServices.Transactions import TransactionManager\r\n\r\nui_doc = DocumentManager.Instance.CurrentUIApplication.ActiveUIDocument\r\ndoc    = ui_doc.Document\r\nactive_view = ui_doc.ActiveView\r\n\r\nrun           = IN[0]\r\ndim_type_name = IN[1] if IN[1] else \"FT-DIM(TXT_4mm)\"\r\noffset_cm     = float(IN[2]) if IN[2] is not None else 50.0\r\noffset_ft     = abs(offset_cm) / 30.48      # 標頭外加距離\r\nselected      = IN[3] if isinstance(IN[3], list) else [IN[3]]\r\nuse_selection = IN[4]\r\n\r\nraw_kw      = str(IN[5]).strip() if len(IN) > 5 and IN[5] else \"\"\r\nlv_keywords = [k.strip() for k in raw_kw.split(\",\") if k.strip()] if raw_kw else []\r\n\r\nHEAD_OFFSET_FT = 50.0 / 304.8   # 立面標頭下方 50mm\r\n\r\n# ── 工具函式 ─────────────────────────────────────────────────────────────────\r\n\r\ndef get_dim_type_name(dt):\r\n    for bip in [BuiltInParameter.SYMBOL_NAME_PARAM, BuiltInParameter.ALL_MODEL_TYPE_NAME]:\r\n        try:\r\n            p = dt.get_Parameter(bip)\r\n            if p and p.AsString(): return p.AsString()\r\n        except: continue\r\n    try: return dt.Name\r\n    except: return None\r\n\r\ndef get_crop_z_range(v):\r\n    try:\r\n        cb = v.CropBox; t = cb.Transform; mn, mx = cb.Min, cb.Max\r\n        zv = [t.OfPoint(XYZ(xi, yi, 0)).Z\r\n              for xi in [mn.X, mx.X]\r\n              for yi in [mn.Y, mx.Y]]\r\n        return min(zv), max(zv)\r\n    except:\r\n        return None, None\r\n\r\ndef get_grid_head_z(grids, v):\r\n    for etype in [DatumExtentType.ViewSpecific, DatumExtentType.Model]:\r\n        try:\r\n            tops = []\r\n            for g in grids:\r\n                clist = list(g.GetCurvesInView(etype, v))\r\n                if clist:\r\n                    c = clist[0]\r\n                    z0, z1 = c.GetEndPoint(0).Z, c.GetEndPoint(1).Z\r\n                    if abs(z0 - z1) > 0.05:\r\n                        tops.append(max(z0, z1))\r\n            if tops: return max(tops)\r\n        except: continue\r\n    if v.CropBoxActive:\r\n        _, z_max = get_crop_z_range(v)\r\n        if z_max is not None: return z_max\r\n    raise Exception(\"無法取得標頭高度，請確認裁剪框已啟用\")\r\n\r\ndef get_levels_in_view(all_levels, v, z_min, z_max):\r\n    TOL = 2.0\r\n    result = []\r\n    for lv in all_levels:\r\n        in_view = False\r\n        try:\r\n            vs = list(lv.GetCurvesInView(DatumExtentType.ViewSpecific, v))\r\n            if vs: in_view = True\r\n        except: pass\r\n        if not in_view:\r\n            if z_min is not None:\r\n                in_view = (z_min - TOL <= lv.Elevation <= z_max + TOL)\r\n            else:\r\n                in_view = True\r\n        if in_view:\r\n            result.append(lv)\r\n    return result\r\n\r\ndef get_level_left_endpoint(levels, v, right_dir):\r\n    min_proj = None\r\n    best_pt  = None\r\n    for lv in levels:\r\n        for etype in [DatumExtentType.ViewSpecific, DatumExtentType.Model]:\r\n            try:\r\n                clist = list(lv.GetCurvesInView(etype, v))\r\n                if not clist: continue\r\n                c = clist[0]\r\n                for i in range(2):\r\n                    ep   = c.GetEndPoint(i)\r\n                    proj = ep.DotProduct(right_dir)\r\n                    if min_proj is None or proj < min_proj:\r\n                        min_proj = proj; best_pt = ep\r\n                break\r\n            except: continue\r\n    return best_pt\r\n\r\ndef collect_grids(use_sel, selected, doc, v):\r\n    \"\"\"收集格線並過濾掉非 Grid 元素（FamilyInstance 等）。\"\"\"\r\n    if use_sel:\r\n        raw = [UnwrapElement(x) for x in selected if x is not None]\r\n        return [g for g in raw if g is not None and g.GetType().Name == \"Grid\"]\r\n    else:\r\n        return list(FilteredElementCollector(doc, v.Id).OfClass(Grid).ToElements())\r\n\r\ndef get_grid_extents_in_view(grids, v, right_v, fwd_v):\r\n    \"\"\"\r\n    取得所有格線在視圖中實際繪製線段的端點範圍。\r\n    回傳 (min_right, max_right, min_fwd, max_fwd)。\r\n    \"\"\"\r\n    min_r = max_r = min_f = max_f = None\r\n    for g in grids:\r\n        curve = None\r\n        for etype in [DatumExtentType.ViewSpecific, DatumExtentType.Model]:\r\n            try:\r\n                clist = list(g.GetCurvesInView(etype, v))\r\n                if clist: curve = clist[0]; break\r\n            except: continue\r\n        if curve is None:\r\n            try: curve = g.Curve\r\n            except: continue\r\n        for i in range(2):\r\n            try:\r\n                ep = curve.GetEndPoint(i)\r\n                r  = ep.DotProduct(right_v)\r\n                f  = ep.DotProduct(fwd_v)\r\n                if min_r is None or r < min_r: min_r = r\r\n                if max_r is None or r > max_r: max_r = r\r\n                if min_f is None or f < min_f: min_f = f\r\n                if max_f is None or f > max_f: max_f = f\r\n            except: pass\r\n    return min_r, max_r, min_f, max_f\r\n\r\ndef make_plan_anchor(r, f, right_v, fwd_v):\r\n    \"\"\"將 right_v / fwd_v 分量轉回世界座標 XYZ（平面視圖）。\"\"\"\r\n    return XYZ(r * right_v.X + f * fwd_v.X,\r\n               r * right_v.Y + f * fwd_v.Y, 0)\r\n\r\n# ── 主程式 ───────────────────────────────────────────────────────────────────\r\n\r\nif not run:\r\n    OUT = \"請將 IN[0] 設為 True 以執行\"\r\nelse:\r\n    try:\r\n        all_dim_types = FilteredElementCollector(doc).OfClass(DimensionType).ToElements()\r\n        dim_type = None\r\n        for dt in all_dim_types:\r\n            if get_dim_type_name(dt) == dim_type_name:\r\n                dim_type = dt; break\r\n        if dim_type is None:\r\n            OUT = \"找不到標註類型：\" + dim_type_name\r\n        else:\r\n            v          = active_view\r\n            view_class = v.GetType().Name\r\n            res        = []\r\n\r\n            # ──────────────────────────────────────────────────────────────\r\n            # 平面圖\r\n            # ──────────────────────────────────────────────────────────────\r\n            if view_class == \"ViewPlan\":\r\n                right_v = v.RightDirection\r\n                fwd_v   = XYZ(-right_v.Y, right_v.X, 0)   # 視圖上方向（在平面內）\r\n\r\n                grids = collect_grids(use_selection, selected, doc, v)\r\n                res.append(\"取得格線：{} 條（{}）\".format(\r\n                    len(grids), \"選取\" if use_selection else \"全視圖\"))\r\n\r\n                if len(grids) < 2:\r\n                    OUT = res + [\"平面可見軸線不足 2 條，請確認選取了格線（非柱/梁）\"]\r\n                else:\r\n                    def is_horiz(g):\r\n                        try:\r\n                            c = g.Curve\r\n                            d = (c.GetEndPoint(1) - c.GetEndPoint(0)).Normalize()\r\n                            return abs(d.DotProduct(right_v)) >= abs(d.DotProduct(fwd_v))\r\n                        except: return False\r\n\r\n                    h_grids = sorted([g for g in grids if     is_horiz(g)],\r\n                                     key=lambda g: g.Curve.GetEndPoint(0).DotProduct(fwd_v))\r\n                    v_grids = sorted([g for g in grids if not is_horiz(g)],\r\n                                     key=lambda g: g.Curve.GetEndPoint(0).DotProduct(right_v))\r\n\r\n                    TransactionManager.Instance.EnsureInTransaction(doc)\r\n\r\n                    # ── H 軸標註（水平格線，量上下間距）────────────────────\r\n                    if len(h_grids) >= 2:\r\n                        refs = ReferenceArray()\r\n                        for g in h_grids: refs.Append(Reference(g))\r\n\r\n                        # 取 H 格線在視圖中的實際端部範圍\r\n                        h_min_r, h_max_r, h_min_f, h_max_f = \\\r\n                            get_grid_extents_in_view(h_grids, v, right_v, fwd_v)\r\n\r\n                        if h_min_r is not None:\r\n                            # 標註線：在最上方格線的頂端（標頭位置）+ offset，水平方向\r\n                            # X 定位在格線最左端（標頭端），Y 定位在最上方端部 + offset\r\n                            anchor = make_plan_anchor(h_min_r, h_max_f + offset_ft, right_v, fwd_v)\r\n                        else:\r\n                            pt     = h_grids[-1].Curve.Evaluate(0.5, True)\r\n                            anchor = XYZ(pt.X + fwd_v.X * offset_ft,\r\n                                         pt.Y + fwd_v.Y * offset_ft, 0)\r\n\r\n                        line = Line.CreateUnbound(anchor, right_v)\r\n                        doc.Create.NewDimension(v, line, refs, dim_type)\r\n                        res.append(\"平面 H軸標註：{} 條\".format(len(h_grids)))\r\n                    else:\r\n                        res.append(\"H軸格線 < 2 條，跳過\")\r\n\r\n                    # ── V 軸標註（垂直格線，量左右間距）────────────────────\r\n                    if len(v_grids) >= 2:\r\n                        refs = ReferenceArray()\r\n                        for g in v_grids: refs.Append(Reference(g))\r\n\r\n                        # 取 V 格線在視圖中的實際端部範圍\r\n                        v_min_r, v_max_r, v_min_f, v_max_f = \\\r\n                            get_grid_extents_in_view(v_grids, v, right_v, fwd_v)\r\n\r\n                        if v_min_r is not None:\r\n                            # 標註線：在最左格線的左側（標頭位置）- offset，垂直方向\r\n                            # X 定位在最左側端部 - offset，Y 定位在最高端部（標頭位置）\r\n                            anchor = make_plan_anchor(v_min_r - offset_ft, v_max_f, right_v, fwd_v)\r\n                        else:\r\n                            pt     = v_grids[0].Curve.Evaluate(0.5, True)\r\n                            anchor = XYZ(pt.X - right_v.X * offset_ft,\r\n                                         pt.Y - right_v.Y * offset_ft, 0)\r\n\r\n                        line = Line.CreateUnbound(anchor, fwd_v)\r\n                        doc.Create.NewDimension(v, line, refs, dim_type)\r\n                        res.append(\"平面 V軸標註：{} 條\".format(len(v_grids)))\r\n                    else:\r\n                        res.append(\"V軸格線 < 2 條，跳過\")\r\n\r\n                    TransactionManager.Instance.TransactionTaskDone()\r\n                    OUT = res\r\n\r\n            # ──────────────────────────────────────────────────────────────\r\n            # 立面 / 剖面\r\n            # ──────────────────────────────────────────────────────────────\r\n            elif view_class == \"ViewSection\":\r\n                right_dir = v.RightDirection\r\n                up_dir    = v.UpDirection\r\n\r\n                raw_grids = collect_grids(use_selection, selected, doc, v)\r\n\r\n                def is_visible_vertical(g):\r\n                    try:\r\n                        c  = g.Curve\r\n                        p0, p1 = c.GetEndPoint(0), c.GetEndPoint(1)\r\n                        return abs(p0.DotProduct(right_dir) - p1.DotProduct(right_dir)) < 0.1\r\n                    except: return False\r\n\r\n                elev_grids = [g for g in raw_grids if is_visible_vertical(g)]\r\n                if len(elev_grids) < 2 and use_selection:\r\n                    view_grids = list(FilteredElementCollector(doc, v.Id).OfClass(Grid).ToElements())\r\n                    elev_grids = [g for g in view_grids if is_visible_vertical(g)]\r\n\r\n                if len(elev_grids) < 2:\r\n                    OUT = \"立面可見軸線不足 2 條（找到 {} 條），ViewDir={}\".format(\r\n                        len(elev_grids), v.ViewDirection)\r\n                else:\r\n                    elev_grids.sort(key=lambda g: g.Curve.GetEndPoint(0).DotProduct(right_dir))\r\n\r\n                    head_z    = get_grid_head_z(elev_grids, v)\r\n                    head_z_mm = head_z * 304.8\r\n                    dim_z     = head_z - HEAD_OFFSET_FT\r\n\r\n                    if head_z_mm > 8000:\r\n                        res.append(\"警告：標頭高度={:.0f}mm\".format(head_z_mm))\r\n\r\n                    h_refs = ReferenceArray()\r\n                    for g in elev_grids: h_refs.Append(Reference(g))\r\n                    anchor = elev_grids[0].Curve.GetEndPoint(0)\r\n                    h_line = Line.CreateUnbound(XYZ(anchor.X, anchor.Y, dim_z), right_dir)\r\n\r\n                    all_levels = list(FilteredElementCollector(doc).OfClass(Level).ToElements())\r\n                    z_min, z_max = get_crop_z_range(v)\r\n                    if z_min is not None:\r\n                        res.append(\"裁剪框：{:.0f}mm ~ {:.0f}mm\".format(\r\n                            z_min * 304.8, z_max * 304.8))\r\n\r\n                    lv_vis = get_levels_in_view(all_levels, v, z_min, z_max)\r\n                    if lv_keywords:\r\n                        lv_vis = [l for l in lv_vis\r\n                                  if any(kw in l.Name for kw in lv_keywords)]\r\n                    lv_vis.sort(key=lambda l: l.Elevation)\r\n\r\n                    TransactionManager.Instance.EnsureInTransaction(doc)\r\n\r\n                    doc.Create.NewDimension(v, h_line, h_refs, dim_type)\r\n                    res.append(\"立面水平標註：{} 條軸線\".format(len(elev_grids)))\r\n\r\n                    if len(lv_vis) >= 2:\r\n                        v_refs = ReferenceArray()\r\n                        for lv in lv_vis:\r\n                            try: v_refs.Append(Reference(lv))\r\n                            except: pass\r\n\r\n                        if v_refs.Size >= 2:\r\n                            left_ep = get_level_left_endpoint(lv_vis, v, right_dir)\r\n                            mid_z   = (lv_vis[0].Elevation + lv_vis[-1].Elevation) / 2.0\r\n                            if left_ep is not None:\r\n                                v_base = XYZ(left_ep.X, left_ep.Y, mid_z)\r\n                                res.append(\"垂直標註線：樓層線端部（自動）\")\r\n                            else:\r\n                                g0     = elev_grids[0].Curve.GetEndPoint(0)\r\n                                v_base = XYZ(g0.X - right_dir.X * offset_ft,\r\n                                             g0.Y - right_dir.Y * offset_ft, mid_z)\r\n                                res.append(\"垂直標註線：IN[2] 備用\")\r\n\r\n                            v_line = Line.CreateUnbound(v_base, up_dir)\r\n                            doc.Create.NewDimension(v, v_line, v_refs, dim_type)\r\n                            res.append(\"立面垂直標註：{} 個樓層（{}～{}）\".format(\r\n                                len(lv_vis), lv_vis[0].Name, lv_vis[-1].Name))\r\n                            if lv_keywords:\r\n                                res.append(\"關鍵字：{}\".format(\"、\".join(lv_keywords)))\r\n                        else:\r\n                            res.append(\"樓層參考建立失敗\")\r\n                    else:\r\n                        res.append(\"可見樓層不足 2 個（找到 {} 個）\".format(len(lv_vis)))\r\n\r\n                    TransactionManager.Instance.TransactionTaskDone()\r\n                    res.append(\"標頭高度：{:.0f}mm\".format(head_z_mm))\r\n                    OUT = res\r\n\r\n            else:\r\n                OUT = \"不支援的視圖類別：{}\".format(view_class)\r\n\r\n    except Exception as e:\r\n        import traceback\r\n        try: TransactionManager.Instance.ForceCloseTransaction()\r\n        except: pass\r\n        OUT = \"錯誤：\" + str(e) + \"\\n\" + traceback.format_exc()",
      "Engine": "CPython3",
      "EngineName": "CPython3",
      "VariableInputPorts": true,
