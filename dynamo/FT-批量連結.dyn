{
  "Uuid": "c2093814-9c6e-42da-988a-968a97a78c4f",
  "IsCustomNode": false,
  "Description": "✨操作說明：需輸入相關資訊 / 檔案選取(可批量選取) / 執行與檢查結果。",
  "Name": "FT-批量連結",
  "ElementResolver": {
    "ResolutionMap": {}
  },
  "Inputs": [
    {
      "Id": "9dfc5e6ae55b4004a54ded81393e5a4f",
      "Name": "檔案選取",
      "Type": "string",
      "Type2": "string",
      "Value": "D:\\富螎_模型",
      "Description": "可讓您選取系統上的目錄，並傳回其路徑",
      "SelectedIndex": 0
    }
  ],
  "Outputs": [],
  "Nodes": [
    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "# -*- coding: utf-8 -*-\r\nimport clr\r\nimport os\r\nclr.AddReference('RevitAPI')\r\nfrom Autodesk.Revit.DB import *\r\nclr.AddReference('RevitServices')\r\nimport RevitServices\r\nfrom RevitServices.Persistence import DocumentManager\r\nfrom RevitServices.Transactions import TransactionManager\r\n\r\ndoc = DocumentManager.Instance.CurrentDBDocument\r\ninput_data = IN[0]\r\npaths = input_data if isinstance(input_data, list) else [input_data]\r\noutput_log = []\r\n\r\nTransactionManager.Instance.EnsureInTransaction(doc)\r\nfor p in paths:\r\n    try:\r\n        m_path = ModelPathUtils.ConvertUserVisiblePathToModelPath(str(p))\r\n        # 僅執行連結與放置 (使用原點對位)\r\n        link_type_id = RevitLinkType.Create(doc, m_path, RevitLinkOptions(False)).ElementId\r\n        RevitLinkInstance.Create(doc, link_type_id, ImportPlacement.Origin)\r\n        output_log.append(\"成功載入: \" + os.path.basename(str(p)))\r\n    except Exception as e:\r\n        output_log.append(\"跳過: \" + os.path.basename(str(p)))\r\nTransactionManager.Instance.TransactionTaskDone()\r\nOUT = output_log",
      "Engine": "IronPython2",
      "EngineName": "IronPython2",
      "VariableInputPorts": true,
      "Id": "125e67a33bdf4641bf37ca19f14710f6",
      "NodeType": "PythonScriptNode",
      "Inputs": [
        {
          "Id": "0de8c345544b4fa9a24b3f2e7cdc2232",
          "Name": "IN[0]",
          "Description": "Input #0",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Outputs": [
        {
          "Id": "e57dfb3c1e6941a188ca417d810f1087",
          "Name": "OUT",
          "Description": "Python 腳本的結果",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Replication": "Disabled",
      "Description": "執行嵌入的 Python 指令碼。"
    },
    {
      "ConcreteType": "Dynamo.Graph.Nodes.ZeroTouch.DSFunction, DynamoCore",
