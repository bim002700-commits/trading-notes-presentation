        },
        {
          "Id": "6d7e0760aa8649e0919bc018ad240604",
          "Name": "includeSubdirectories",
          "Description": "設定為 true 可在子目錄 (遞迴) 中包括檔案和資料夾，設定為 false 就只能在給定目錄的最上層包括結果。\n\nbool\n預設值 : false",
          "UsingDefaultValue": true,
