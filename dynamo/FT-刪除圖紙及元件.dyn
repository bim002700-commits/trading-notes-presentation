{
  "Uuid": "5a896cfe-7a69-44c8-9a9c-bc1ee9c0ae12",
  "IsCustomNode": false,
  "Description": "🔄操作說明：開啟檔案/執行/自動另存新檔_Purge。",
  "Name": "FT-刪除圖紙及元件",
  "ElementResolver": {
    "ResolutionMap": {}
  },
  "Inputs": [],
  "Outputs": [],
  "Nodes": [
    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "import clr\r\nimport os\r\n\r\nclr.AddReference('RevitAPI')\r\nfrom Autodesk.Revit.DB import *\r\n\r\nclr.AddReference('RevitServices')\r\nimport RevitServices\r\nfrom RevitServices.Persistence import DocumentManager\r\nfrom RevitServices.Transactions import TransactionManager\r\n\r\ndoc = DocumentManager.Instance.CurrentDBDocument\r\n\r\n# --- 1. 路徑處理 ---\r\ncurrent_path = doc.PathName\r\n\r\nif not current_path:\r\n    OUT = \"❌ 錯誤：檔案尚未儲存，請先手動儲存原始檔。\"\r\nelse:\r\n    try:\r\n        folder = os.path.dirname(current_path)\r\n        filename = os.path.basename(current_path)\r\n        name, ext = os.path.splitext(filename)\r\n        new_path = os.path.join(folder, name + \"_Purge\" + ext)\r\n\r\n        # --- 2. 核心操作：先另存新檔 ---\r\n        # 這樣接下來的所有動作都是在 _Purge 這個副本上進行\r\n        save_opts = SaveAsOptions()\r\n        save_opts.OverwriteExistingFile = True\r\n        save_opts.Compact = True\r\n        \r\n        if doc.IsWorkshared:\r\n            ws_options = WorksharingSaveAsOptions()\r\n            ws_options.SaveAsCentral = True \r\n            save_opts.SetWorksharingOptions(ws_options)\r\n\r\n        # 立即執行另存\r\n        doc.SaveAs(new_path, save_opts)\r\n\r\n        # --- 3. 開始清理作業 ---\r\n        TransactionManager.Instance.EnsureInTransaction(doc)\r\n        \r\n        sheet_count = 0\r\n        view_count = 0\r\n\r\n        # A. 刪除圖紙\r\n        sheets = FilteredElementCollector(doc).OfClass(ViewSheet).ToElements()\r\n        for s in sheets:\r\n            if s and s.IsValidObject:\r\n                try:\r\n                    if s.Pinned: s.Pinned = False\r\n                    doc.Delete(s.Id)\r\n                    sheet_count += 1\r\n                except: pass\r\n\r\n        # B. 刪除非必要視圖\r\n        views = FilteredElementCollector(doc).OfClass(View).ToElements()\r\n        active_view_id = doc.ActiveView.Id\r\n        for v in views:\r\n            if v and v.IsValidObject:\r\n                if v.IsTemplate or v.Id == active_view_id: continue\r\n                if v.CanBePrinted or v.ViewType == ViewType.Section:\r\n                    try:\r\n                        if v.Pinned: v.Pinned = False\r\n                        doc.Delete(v.Id)\r\n                        view_count += 1\r\n                    except: pass\r\n\r\n        # C. 深度 Purge\r\n        for i in range(2):\r\n            try:\r\n                from System.Collections.Generic import List as ListGen\r\n                unused = doc.GetUnusedElements(ListGen[ElementId]())\r\n            except:\r\n                try: unused = doc.GetUnusedElements(ElementId.InvalidElementId)\r\n                except: unused = []\r\n            \r\n            if not unused: break\r\n            for u_id in unused:\r\n                try: doc.Delete(u_id)\r\n                except: pass\r\n\r\n        TransactionManager.Instance.TransactionTaskDone()\r\n\r\n        # --- 4. 修改完畢後存檔 ---\r\n        doc.Save()\r\n        \r\n        OUT = \"🛡️ 清理完成！\\n\" + \\\r\n              \"1. 檔案已產出: {}\\n\".format(name + \"_Purge\" + ext) + \\\r\n              \"2. 刪除圖紙: {} 張\\n\".format(sheet_count) + \\\r\n              \"3. 刪除視圖: {} 個\".format(view_count)\r\n\r\n    except Exception as ex:\r\n        if TransactionManager.Instance.TransactionTaskDone(): pass\r\n        OUT = \"❌ 執行失敗: \" + str(ex)",
      "Engine": "CPython3",
      "EngineName": "CPython3",
      "VariableInputPorts": true,
