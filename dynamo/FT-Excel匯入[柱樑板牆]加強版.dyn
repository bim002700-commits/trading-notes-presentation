  "Nodes": [
    {
      "ConcreteType": "CoreNodeModels.Input.Filename, CoreNodeModels",
      "Id": "a395a41170674ce3a14fc0330a9a415c",
      "NodeType": "ExtensionNode",
      "Inputs": [],
      "Outputs": [
        {
          "Id": "f7866a2c8f724a4c8334fda98943798c",
          "Name": "",
          "Description": "檔案路徑",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Replication": "Disabled",
      "Description": "可讓您選取系統上的檔案，並傳回其檔案路徑",
      "HintPath": "C:\\Users\\002700\\Downloads\\Revit匯入表_v2.csv",
      "InputValue": "C:\\Users\\002700\\Downloads\\Revit匯入表_v2.csv"
    },
    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "# -*- coding: utf-8 -*-\r\nimport clr\r\nimport os\r\nimport System\r\n\r\nclr.AddReference('RevitAPI')\r\nfrom Autodesk.Revit.DB import *\r\n\r\nclr.AddReference('RevitServices')\r\nfrom RevitServices.Persistence import DocumentManager\r\nfrom RevitServices.Transactions import TransactionManager\r\n\r\ndoc = DocumentManager.Instance.CurrentDBDocument\r\n\r\ndef to_ft(val):\r\n    try:\r\n        if val is None: return None\r\n        s = \"\".join(c for c in str(val) if c.isdigit() or c in \".-\")\r\n        if not s: return None\r\n        return float(s) / 304.8\r\n    except: return None\r\n\r\n# 讀取輸入路徑\r\npaths = [str(p).strip() for p in IN if p] if isinstance(IN, list) else ([str(IN).strip()] if IN else [])\r\nresults = []\r\n\r\nTransactionManager.Instance.EnsureInTransaction(doc)\r\n\r\ntry:\r\n    for csv_path in paths:\r\n        if not os.path.exists(csv_path): continue\r\n        \r\n        file_name = os.path.basename(csv_path)\r\n        import io\r\n        rows = []\r\n        with io.open(csv_path, 'r', encoding='utf-8-sig') as f:\r\n            for line in f:\r\n                parts = [p.strip() for p in line.split(',')]\r\n                if len(parts) >= 2 and parts[1]: rows.append(parts)\r\n\r\n        if len(rows) <= 3: continue\r\n        results.append(\"📂 檔案: \" + file_name)\r\n\r\n        # --- 根據檔案名稱決定對應邏輯 ---\r\n        # 區分 樑(Beam) 與 柱(Column) 的欄位索引\r\n        mode = \"COLUMN\" if \"柱\" in file_name else \"BEAM\"\r\n\r\n        for i, row in enumerate(rows[3:]):\r\n            try:\r\n                fam_name, type_name = row[0], row[1]\r\n                collector = FilteredElementCollector(doc).OfClass(Family).ToElements()\r\n                target_fam = next((f for f in collector if f.Name == fam_name), None)\r\n                if not target_fam: continue\r\n\r\n                symbols = [doc.GetElement(s_id) for s_id in target_fam.GetFamilySymbolIds()]\r\n                target_type = next((s for s in symbols if s.get_Parameter(BuiltInParameter.SYMBOL_NAME_PARAM).AsString() == type_name), None)\r\n                if not target_type: target_type = symbols[0].Duplicate(type_name)\r\n                if not target_type.IsActive: target_type.Activate()\r\n\r\n                # 定義該族群所有可用的參數字典\r\n                p_dict = {p.Definition.Name.lower(): p for p in target_type.Parameters}\r\n\r\n                applied = []\r\n                \r\n                # 配置映射表格\r\n                if mode == \"BEAM\":\r\n                    # 樑：C=b(2), D=h(3), E=tw(4), F=tf(5)\r\n                    mapping = [(2, [\"b\", \"寬度\"]), (3, [\"h\", \"高度\"]), (4, [\"tw\", \"腹板厚度\"]), (5, [\"tf\", \"翼板厚度\"])]\r\n                else:\r\n                    # 柱：C=b(2), D=h(3), E=直徑(4), F=tw(5), G=tf(6), H=t1(7), I=t2(8), J=灌漿X(9), K=灌漿Y(10)\r\n                    mapping = [(2, [\"b\", \"X\"]), (3, [\"h\", \"Y\"]), (4, [\"直徑\"]), (5, [\"tw\"]), (6, [\"tf\"]), \r\n                               (7, [\"t1\", \"t\"]), (8, [\"t2\"]), (9, [\"柱內灌漿X\"]), (10, [\"柱內灌漿Y\"])]\r\n\r\n                for col_idx, names in mapping:\r\n                    if len(row) > col_idx:\r\n                        val_ft = to_ft(row[col_idx])\r\n                        if val_ft is None: continue\r\n                        \r\n                        # 嘗試匹配正確的參數名稱\r\n                        target_p = None\r\n                        for name in names:\r\n                            if name.lower() in p_dict:\r\n                                target_p = p_dict[name.lower()]\r\n                                break\r\n                        \r\n                        if target_p and not target_p.IsReadOnly:\r\n                            target_p.Set(val_ft)\r\n                            applied.append(target_p.Definition.Name)\r\n\r\n                results.append(\"  ✅ {}: ({})\".format(type_name, \",\".join(applied)))\r\n            except Exception as e_row:\r\n                results.append(\"  ❌ 列 {} 錯誤: {}\".format(i+4, str(e_row)))\r\n\r\nexcept Exception as e_global:\r\n    results.append(\"🔥 嚴重錯誤: \" + str(e_global))\r\n\r\nTransactionManager.Instance.TransactionTaskDone()\r\nOUT = results",
      "Engine": "CPython3",
      "EngineName": "CPython3",
      "VariableInputPorts": true,
      "Id": "7f34e125b7dd4ef7b04eeaddd8b5a619",
